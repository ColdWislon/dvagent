// <proj>_env -- agents + scoreboard + coverage + virtual sequencer
// Substitute <proj>/<name> (one block per interface/agent). Matches the
// uvm-gen generated shape: env-level children are plain-named, the single
// <proj>_env_cfg travels via uvm_config_db (or is poked by a parent env),
// vsequencer handles are <name>_sqr and stay null when passive.
class <proj>_env extends uvm_env;
  `uvm_component_utils(<proj>_env)

  <proj>_env_cfg cfg;

  <proj>_<name>_agent <name>_agent;
  <proj>_<name>_cov   <name>_cov;
  <proj>_scoreboard   scoreboard;
  <proj>_vsequencer   vsequencer;

  function new(string name, uvm_component parent);
    super.new(name, parent);
  endfunction

  virtual function void build_phase(uvm_phase phase);
    super.build_phase(phase);
    if (cfg == null && !uvm_config_db#(<proj>_env_cfg)::get(this, "", "cfg", cfg))
      `uvm_fatal("NOCFG", "no <proj>_env_cfg provided from above")

    <name>_agent     = <proj>_<name>_agent::type_id::create("<name>_agent", this);
    <name>_agent.cfg = cfg.<name>_cfg;

    if (cfg.has_scoreboard) begin
      scoreboard     = <proj>_scoreboard::type_id::create("scoreboard", this);
      scoreboard.cfg = cfg;
    end
    if (cfg.has_coverage && cfg.<name>_cfg.has_coverage) begin
      <name>_cov     = <proj>_<name>_cov::type_id::create("<name>_cov", this);
      <name>_cov.cfg = cfg;
    end

    vsequencer     = <proj>_vsequencer::type_id::create("vsequencer", this);
    vsequencer.cfg = cfg;
  endfunction

  virtual function void connect_phase(uvm_phase phase);
    super.connect_phase(phase);
    // analysis fan-out per agent
    if (scoreboard != null)
      <name>_agent.ap.connect(scoreboard.<name>_imp);
    if (<name>_cov != null)
      <name>_agent.ap.connect(<name>_cov.analysis_export);
    // virtual sequencer wiring -- null when passive (SoC integration)
    vsequencer.<name>_sqr = (cfg.<name>_cfg.is_active == UVM_ACTIVE)
                            ? <name>_agent.m_sequencer : null;
  endfunction

endclass : <proj>_env
