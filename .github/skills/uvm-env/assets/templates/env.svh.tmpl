// <proj>_env -- agents + scoreboard + coverage + virtual sequencer
// Substitute <proj>/<PROJ> and the agent roles. Everything is config-driven.
`ifndef <PROJ>_ENV_SVH
`define <PROJ>_ENV_SVH

class <proj>_env extends uvm_env;
  `uvm_component_utils(<proj>_env)

  <proto>_agent      m_master_agent;
  <proto>_agent      m_slave_agent;
  <proj>_scoreboard  m_scoreboard;
  <proj>_coverage    m_coverage;
  <proj>_vsequencer  m_vsequencer;
  <proj>_env_cfg     m_cfg;

  function new(string name, uvm_component parent);
    super.new(name, parent);
  endfunction

  virtual function void build_phase(uvm_phase phase);
    super.build_phase(phase);
    if (!uvm_config_db#(<proj>_env_cfg)::get(this, "", "cfg", m_cfg))
      `uvm_fatal(get_type_name(), "no env cfg")

    m_master_agent = <proto>_agent::type_id::create("m_master_agent", this);
    m_slave_agent  = <proto>_agent::type_id::create("m_slave_agent",  this);
    m_scoreboard   = <proj>_scoreboard::type_id::create("m_scoreboard", this);
    m_coverage     = <proj>_coverage::type_id::create("m_coverage", this);
    m_vsequencer   = <proj>_vsequencer::type_id::create("m_vsequencer", this);
  endfunction

  virtual function void connect_phase(uvm_phase phase);
    super.connect_phase(phase);
    // analysis paths
    m_master_agent.ap.connect(m_scoreboard.imp_master);
    m_slave_agent.ap.connect(m_scoreboard.imp_slave);
    m_master_agent.ap.connect(m_coverage.analysis_export);
    // virtual sequencer wiring
    m_vsequencer.m_master_seqr = m_master_agent.m_sequencer;
    m_vsequencer.m_slave_seqr  = m_slave_agent.m_sequencer;
  endfunction

endclass : <proj>_env

`endif // <PROJ>_ENV_SVH
