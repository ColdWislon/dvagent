// <proj>_tb_top -- testbench top: interfaces, clock/reset, DUT, UVM bootstrap.
// Substitute <proj>/<PROJ>; add one <proto>_if instance + config_db set per
// agent. DUT ports are NOT auto-connected -- that is the DUT-integration step.
`ifndef <PROJ>_TB_TOP_SV
`define <PROJ>_TB_TOP_SV

module <proj>_tb_top;

  import uvm_pkg::*;
  `include "uvm_macros.svh"
  import <proj>_test_pkg::*;

  // ---- Clock / reset generation -------------------------------------------
  logic clk;
  logic rst_n;

  initial begin
    clk = 1'b0;
    forever #5ns clk = ~clk;   // 100 MHz -- adjust to the DUT's needs
  end

  initial begin
    rst_n = 1'b0;
    repeat (10) @(posedge clk);
    rst_n = 1'b1;
  end

  // ---- Interfaces (one per agent) -----------------------------------------
  <proto>_if <proto>_if_i (.clk(clk), .rst_n(rst_n));
  // TODO(vip): instantiate any Cadence VIP interfaces here.

  // ---- DUT -- ports wired in the DUT-integration step, not here -----------
  <dut_module> dut (
    // TODO(connect-dut): connect DUT ports to the interface(s) above, e.g.
    //   .clk         (clk),
    //   .rst_n       (rst_n),
    //   .<proto>_valid (<proto>_if_i.valid),
    //   .<proto>_data  (<proto>_if_i.data),
    // then prove it with `make compile`.
  );

  // ---- UVM bootstrap: publish every vif, then launch ----------------------
  initial begin
    uvm_config_db#(virtual <proto>_if)::set(null, "uvm_test_top", "<proto>_vif", <proto>_if_i);
    run_test();   // test selected by +UVM_TESTNAME (make run TEST=...)
  end

endmodule : <proj>_tb_top

`endif // <PROJ>_TB_TOP_SV
