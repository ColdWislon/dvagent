// -----------------------------------------------------------------------------
// {{ ip }}_env — environment wiring agents, VIPs, scoreboard, coverage,
// virtual sequencer and the RAL hook
// Generated by uvm-gen {{ gen_version }}.
//
// Reusable vertically: the ONLY external contract is one {{ ip }}_env_cfg
// object (fetched from the config_db under this component). No absolute
// hierarchy, no testbench references.
// -----------------------------------------------------------------------------
`ifndef {{ IP }}_ENV_SV
`define {{ IP }}_ENV_SV

class {{ ip }}_env extends uvm_env;

  {{ ip }}_env_cfg cfg;

{% for a in agents %}
  {{ ip }}_{{ a.name }}_agent m_{{ a.name }}_agent;
{% endfor %}
{% for v in vips %}
  {{ ip }}_{{ v.name }}_vip_agent m_{{ v.name }}_agent;
{% endfor %}
  {{ ip }}_scoreboard m_scoreboard;
{% for a in agents %}
  {{ ip }}_{{ a.name }}_coverage m_{{ a.name }}_coverage;
{% endfor %}
  {{ ip }}_virtual_sequencer m_vsequencer;

  // RAL plumbing — regmodel always available when cfg.has_ral; the bus-side
  // adapter/predictor only exist while this env owns the bus (standalone).
  {{ ip }}_reg_block  regmodel;
  {{ ip }}_reg_adapter m_reg_adapter;
{% if reg_agent %}
  uvm_reg_predictor #({{ ip }}_{{ reg_agent.name }}_seq_item) m_predictor;
{% endif %}

  `uvm_component_utils({{ ip }}_env)

  function new(string name, uvm_component parent);
    super.new(name, parent);
  endfunction

  virtual function void build_phase(uvm_phase phase);
    super.build_phase(phase);

    // The single external dependency: one env config from the parent
    // (standalone test or SoC env).
    if (cfg == null && !uvm_config_db#({{ ip }}_env_cfg)::get(this, "", "cfg", cfg))
      `uvm_fatal("NOCFG",
        "no {{ ip }}_env_cfg — set it with uvm_config_db#({{ ip }}_env_cfg)::set(this, \"<env instance>\", \"cfg\", cfg)")

    // Agents — sub-configs (including vifs and is_active) come from cfg
{% for a in agents %}
    m_{{ a.name }}_agent = {{ ip }}_{{ a.name }}_agent::type_id::create("m_{{ a.name }}_agent", this);
    m_{{ a.name }}_agent.cfg = cfg.{{ a.name }}_cfg;
{% endfor %}

{% if vips %}
    // Cadence VIP wrappers
{% for v in vips %}
    m_{{ v.name }}_agent = {{ ip }}_{{ v.name }}_vip_agent::type_id::create("m_{{ v.name }}_agent", this);
    m_{{ v.name }}_agent.cfg = cfg.{{ v.name }}_cfg;
{% endfor %}

{% endif %}
    if (cfg.enable_scoreboard) begin
      m_scoreboard = {{ ip }}_scoreboard::type_id::create("m_scoreboard", this);
      m_scoreboard.cfg = cfg;
    end

{% if agents %}
    if (cfg.enable_coverage) begin
{% for a in agents %}
      m_{{ a.name }}_coverage = {{ ip }}_{{ a.name }}_coverage::type_id::create("m_{{ a.name }}_coverage", this);
      m_{{ a.name }}_coverage.cfg = cfg.{{ a.name }}_cfg;
{% endfor %}
    end

{% endif %}
    m_vsequencer = {{ ip }}_virtual_sequencer::type_id::create("m_vsequencer", this);
    m_vsequencer.cfg = cfg;

    // RAL hook: build our own register model when standalone; an SoC that
    // instantiated {{ ip }}_reg_block inside its own model just sets
    // cfg.regmodel (and cfg.env_owns_bus=0) instead.
    if (cfg.has_ral) begin
      if (cfg.regmodel == null) begin
        cfg.regmodel = {{ ip }}_reg_block::type_id::create("regmodel");
        cfg.regmodel.build(cfg.ral_base_addr);
        cfg.regmodel.lock_model();
      end
      regmodel = cfg.regmodel;
      if (cfg.env_owns_bus) begin
        m_reg_adapter = {{ ip }}_reg_adapter::type_id::create("m_reg_adapter");
{% if reg_agent %}
        m_predictor = uvm_reg_predictor #({{ ip }}_{{ reg_agent.name }}_seq_item)::type_id::create("m_predictor", this);
{% endif %}
      end
    end
  endfunction

  virtual function void connect_phase(uvm_phase phase);
    super.connect_phase(phase);

    // Analysis wiring: every monitor into the scoreboard (and coverage)
{% for a in agents %}
    if (m_scoreboard != null)
      m_{{ a.name }}_agent.analysis_port.connect(m_scoreboard.{{ a.name }}_export);
    if (m_{{ a.name }}_coverage != null)
      m_{{ a.name }}_agent.analysis_port.connect(m_{{ a.name }}_coverage.analysis_export);
{% endfor %}
{% for v in vips %}
    if (m_scoreboard != null)
      m_{{ v.name }}_agent.analysis_port.connect(m_scoreboard.{{ v.name }}_export);
{% endfor %}

    // Virtual sequencer handles — stay null for passive agents
{% for a in agents %}
    if (cfg.{{ a.name }}_cfg.is_active == UVM_ACTIVE)
      m_vsequencer.m_{{ a.name }}_sequencer = m_{{ a.name }}_agent.m_sequencer;
{% endfor %}
{% for v in vips %}
    m_vsequencer.m_{{ v.name }}_sequencer = m_{{ v.name }}_agent.m_sequencer_h;
{% endfor %}

    // RAL bus wiring — only when this env owns the register bus
    if (cfg.has_ral && cfg.env_owns_bus && regmodel != null) begin
{% if reg_agent %}
      // TODO(ral): retarget at the real register bus agent if '{{ reg_agent.name }}' is not it
      if (cfg.{{ reg_agent.name }}_cfg.is_active == UVM_ACTIVE) begin
        regmodel.default_map.set_sequencer(m_{{ reg_agent.name }}_agent.m_sequencer, m_reg_adapter);
        regmodel.default_map.set_auto_predict(0);
      end
      m_predictor.map     = regmodel.default_map;
      m_predictor.adapter = m_reg_adapter;
      m_{{ reg_agent.name }}_agent.analysis_port.connect(m_predictor.bus_in);
{% else %}
      // TODO(ral): regmodel.default_map.set_sequencer(<register bus sequencer>, m_reg_adapter);
{% endif %}
    end
  endfunction

endclass : {{ ip }}_env

`endif // {{ IP }}_ENV_SV
