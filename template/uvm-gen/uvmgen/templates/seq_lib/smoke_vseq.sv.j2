// -----------------------------------------------------------------------------
// {{ ip }}_smoke_vseq — trivial virtual sequence used by {{ ip }}_smoke_test
// Generated by uvm-gen {{ gen_version }}.
//
// Drives a short traffic burst on every ACTIVE agent. Passive agents are
// skipped at run time: the same sequence works unchanged when an SoC env
// flips every agent passive through {{ ip }}_env_cfg — that null-check is the
// vertical-reuse demonstration.
// -----------------------------------------------------------------------------
`ifndef {{ IP }}_SMOKE_VSEQ_SV
`define {{ IP }}_SMOKE_VSEQ_SV

class {{ ip }}_smoke_vseq extends {{ ip }}_base_vseq;

  `uvm_object_utils({{ ip }}_smoke_vseq)

  function new(string name = "{{ ip }}_smoke_vseq");
    super.new(name);
  endfunction

  virtual task body();
{% for a in agents %}
    if (p_sequencer.m_{{ a.name }}_sequencer != null) begin
      {{ ip }}_{{ a.name }}_base_seq {{ a.name }}_seq;
      {{ a.name }}_seq = {{ ip }}_{{ a.name }}_base_seq::type_id::create("{{ a.name }}_seq");
      if (!{{ a.name }}_seq.randomize())
        `uvm_error(get_type_name(), "randomize() failed for {{ a.name }}_seq")
      {{ a.name }}_seq.start(p_sequencer.m_{{ a.name }}_sequencer);
    end
    else begin
      `uvm_info(get_type_name(),
                "agent '{{ a.name }}' is passive — no stimulus driven on it", UVM_LOW)
    end
{% endfor %}
{% for v in vips %}
    // TODO(vip): start Cadence {{ v.title }} VIP sequences on
    // p_sequencer.m_{{ v.name }}_sequencer once the VIP wrapper is wired.
{% endfor %}
{% if not agents and not vips %}
    `uvm_info(get_type_name(), "no agents configured — nothing to drive", UVM_LOW)
{% endif %}
  endtask

endclass : {{ ip }}_smoke_vseq

`endif // {{ IP }}_SMOKE_VSEQ_SV
