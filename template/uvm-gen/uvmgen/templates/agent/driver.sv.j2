// -----------------------------------------------------------------------------
// {{ ip }}_{{ agent.name }}_driver — driver of the '{{ agent.name }}' agent
// Generated by uvm-gen {{ gen_version }}.
// -----------------------------------------------------------------------------
`ifndef {{ IP }}_{{ agent.NAME }}_DRIVER_SV
`define {{ IP }}_{{ agent.NAME }}_DRIVER_SV

class {{ ip }}_{{ agent.name }}_driver extends uvm_driver #({{ ip }}_{{ agent.name }}_seq_item);

  {{ ip }}_{{ agent.name }}_agent_cfg cfg;

  `uvm_component_utils({{ ip }}_{{ agent.name }}_driver)

  function new(string name, uvm_component parent);
    super.new(name, parent);
  endfunction

  virtual function void build_phase(uvm_phase phase);
    super.build_phase(phase);
    if (cfg == null && !uvm_config_db#({{ ip }}_{{ agent.name }}_agent_cfg)::get(this, "", "cfg", cfg))
      `uvm_fatal("NOCFG", "no {{ ip }}_{{ agent.name }}_agent_cfg — the agent assigns it before build")
    if (cfg.vif == null)
      `uvm_fatal("NOVIF", "cfg.vif is null — set the virtual interface in {{ ip }}_env_cfg")
  endfunction

  virtual task run_phase(uvm_phase phase);
    drive_idle();
    wait (cfg.vif.rst_n === 1'b1);
    forever begin
      seq_item_port.get_next_item(req);
      `uvm_info(get_type_name(), $sformatf("driving: %s", req.convert2string()), UVM_HIGH)
      drive_item(req);
      seq_item_port.item_done();
    end
  endtask

  // Put the bus into a safe idle state
  virtual task drive_idle();
    cfg.vif.drv_cb.valid <= 1'b0;
    cfg.vif.drv_cb.data  <= '0;
  endtask

  // ---------------------------------------------------------------------------
  // TODO(protocol): implement the real '{{ agent.name }}' pin-level protocol.
  // The generic single-cycle valid/data pulse below only exists so a freshly
  // generated environment runs its smoke test out of the box.
  // ---------------------------------------------------------------------------
  virtual task drive_item({{ ip }}_{{ agent.name }}_seq_item item);
    @(cfg.vif.drv_cb);
    cfg.vif.drv_cb.valid <= 1'b1;
    cfg.vif.drv_cb.data  <= item.data;
    @(cfg.vif.drv_cb);
    cfg.vif.drv_cb.valid <= 1'b0;
    // TODO(protocol): honor the ready/response side of the handshake
  endtask

endclass : {{ ip }}_{{ agent.name }}_driver

`endif // {{ IP }}_{{ agent.NAME }}_DRIVER_SV
