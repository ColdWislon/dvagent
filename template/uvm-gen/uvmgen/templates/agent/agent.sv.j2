  {{ ip }}_{{ agent.name }}_agent_cfg cfg;

  {{ ip }}_{{ agent.name }}_monitor   m_monitor;
  {{ ip }}_{{ agent.name }}_driver    m_driver;     // active only
  {{ ip }}_{{ agent.name }}_sequencer m_sequencer;  // active only

  // Monitor traffic re-published at agent level (stable connection point)
  uvm_analysis_port #({{ ip }}_{{ agent.name }}_seq_item) analysis_port;

  `uvm_component_utils({{ ip }}_{{ agent.name }}_agent)

  function new(string name, uvm_component parent);
