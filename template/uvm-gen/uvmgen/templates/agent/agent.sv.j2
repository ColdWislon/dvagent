    analysis_port = new("analysis_port", this);

    m_monitor = {{ ip }}_{{ agent.name }}_monitor::type_id::create("m_monitor", this);
    m_monitor.cfg = cfg;

    // Vertical reuse: driver/sequencer do not even exist in passive mode
    if (is_active == UVM_ACTIVE) begin
      m_driver    = {{ ip }}_{{ agent.name }}_driver::type_id::create("m_driver", this);
      m_sequencer = {{ ip }}_{{ agent.name }}_sequencer::type_id::create("m_sequencer", this);
