#!/usr/bin/env python3
"""matrix_report.py — configurations vs. verification status (`make matrix`).

Generated by uvm-gen {{ gen_version }}. Aggregates verif_matrix.yaml by
(config_name, param_hash) and prints a sign-off summary table. --yaml emits
the same aggregate machine-readably.
"""

import argparse
import sys
from pathlib import Path

import yaml


def aggregate(runs):
    groups = {}
    for run in runs:
        key = (str(run.get("config_name", "?")), str(run.get("param_hash", "?")))
        group = groups.setdefault(key, {
            "config_name": key[0],
            "param_hash": key[1],
            "params": run.get("params") or {},
            "runs": 0, "pass": 0, "fail": 0,
            "tests": [], "seeds": [],
            "last_run": "", "git_rev": "", "coverage": None,
        })
        group["runs"] += 1
        if run.get("status") == "pass":
            group["pass"] += 1
        else:
            group["fail"] += 1
        test = run.get("test")
        if test and test not in group["tests"]:
            group["tests"].append(test)
        if run.get("seed") is not None:
            group["seeds"].append(str(run.get("seed")))
        date = str(run.get("date") or "")
        if date >= group["last_run"]:
            group["last_run"] = date
            group["git_rev"] = str(run.get("git_rev") or group["git_rev"])
        if run.get("coverage") is not None:
            group["coverage"] = run["coverage"]
    return [groups[key] for key in sorted(groups)]


def print_table(groups):
    headers = ["CONFIG", "PARAM_HASH", "RUNS", "PASS", "FAIL",
               "COV%", "LAST RUN", "GIT", "STATUS"]
    rows = []
    for group in groups:
        coverage = "-" if group["coverage"] is None else ("%.1f" % group["coverage"])
        status = "CLEAN" if group["fail"] == 0 else "FAILING"
        rows.append([
            group["config_name"], group["param_hash"], str(group["runs"]),
            str(group["pass"]), str(group["fail"]), coverage,
            group["last_run"], group["git_rev"], status,
        ])
    widths = [max(len(headers[i]), *(len(row[i]) for row in rows))
              for i in range(len(headers))]
    line = "  ".join(h.ljust(widths[i]) for i, h in enumerate(headers))
    print(line)
    print("-" * len(line))
    for row in rows:
        print("  ".join(cell.ljust(widths[i]) for i, cell in enumerate(row)))
    print()
    for group in groups:
        print("%s (%s): tests=[%s], %d distinct seed(s)"
              % (group["config_name"], group["param_hash"],
                 ", ".join(group["tests"]), len(set(group["seeds"]))))


def main(argv=None):
    ap = argparse.ArgumentParser(description="summarize verif_matrix.yaml")
    ap.add_argument("matrix", help="path to verif_matrix.yaml")
    ap.add_argument("--yaml", action="store_true",
                    help="dump the aggregate as YAML instead of a table")
    args = ap.parse_args(argv)

    path = Path(args.matrix)
    if not path.is_file():
        print("matrix_report: %s not found — run `make run` first" % path)
        return 0
    data = yaml.safe_load(path.read_text()) or {}
    runs = data.get("runs") or []
    if not runs:
        print("matrix_report: no runs recorded yet — run `make run` first")
        return 0

    groups = aggregate(runs)
    if args.yaml:
        print(yaml.safe_dump({"configs": groups}, sort_keys=False,
                             default_flow_style=False))
        return 0
    print("verification matrix: %d run(s), %d configuration(s)\n"
          % (len(runs), len(groups)))
    print_table(groups)
    return 0


if __name__ == "__main__":
    sys.exit(main())
