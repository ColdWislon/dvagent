# ==============================================================================
# {{ ip }} DV filelist (generated by uvm-gen {{ gen_version }})
# Compile order matters: interfaces -> agent pkgs -> VIP wrappers -> env ->
# sequences -> tests -> tb.
# Anchored on ${{ IP }}_VERIF_HOME (exported by sim/Makefile) so an SoC flow
# can pull this exact file into its own build with a single -f.
# ==============================================================================

# Interfaces
{% for a in agents %}
${{ IP }}_VERIF_HOME/agents/{{ a.name }}_agent/{{ ip }}_{{ a.name }}_if.sv
{% endfor %}

# Agent packages
{% for a in agents %}
-incdir ${{ IP }}_VERIF_HOME/agents/{{ a.name }}_agent
${{ IP }}_VERIF_HOME/agents/{{ a.name }}_agent/{{ ip }}_{{ a.name }}_agent_pkg.sv
{% endfor %}

{% if vips %}
# Cadence VIP wrapper packages
{% for v in vips %}
-incdir ${{ IP }}_VERIF_HOME/vip/{{ v.name }}_vip
${{ IP }}_VERIF_HOME/vip/{{ v.name }}_vip/{{ ip }}_{{ v.name }}_vip_pkg.sv
{% endfor %}

{% endif %}
# Environment
-incdir ${{ IP }}_VERIF_HOME/env
${{ IP }}_VERIF_HOME/env/{{ ip }}_env_pkg.sv

# Virtual sequences
-incdir ${{ IP }}_VERIF_HOME/seq_lib
${{ IP }}_VERIF_HOME/seq_lib/{{ ip }}_seq_lib_pkg.sv

# Tests
-incdir ${{ IP }}_VERIF_HOME/tests
${{ IP }}_VERIF_HOME/tests/{{ ip }}_test_pkg.sv

# Testbench top (+ DUT stub, active only under +define+{{ IP }}_USE_DUT_STUB)
${{ IP }}_VERIF_HOME/tb/{{ ip }}_dut_stub.sv
${{ IP }}_VERIF_HOME/tb/{{ ip }}_tb_top.sv
