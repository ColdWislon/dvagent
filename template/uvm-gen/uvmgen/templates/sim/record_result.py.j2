#!/usr/bin/env python3
"""record_result.py — append one simulation record to verif_matrix.yaml.

Generated by uvm-gen {{ gen_version }}. Called by `make run` after every
simulation; vManager regression runs go through `make run` too, so every
regression lands here as well. Records are human-auditable YAML and
machine-queryable (yaml.safe_load(...)["runs"]). Concurrent regression runs
are safe: the file is updated under an exclusive lock.
"""

import argparse
import datetime
import re
import subprocess
import sys
from pathlib import Path

import yaml

sys.path.insert(0, str(Path(__file__).resolve().parent))
import cfg2args  # noqa: E402  (sibling module: same config parsing/hash)

try:
    import fcntl
except ImportError:  # non-POSIX fallback: no locking
    fcntl = None

MATRIX_HEADER = """\
# ============================================================================
# {{ ip }} verification tracking matrix — one record per simulation run,
# appended automatically by `make run` (and thus by vManager regressions).
#   view    : make matrix
#   query   : python3 -c "import yaml; print(yaml.safe_load(open('verif_matrix.yaml'))['runs'])"
# ============================================================================
"""

UVM_COUNT_RE = re.compile(r"UVM_(ERROR|FATAL)\s*:\s*(\d+)")
SEED_RES = [
    re.compile(r"SVSEED\D{0,32}?(\d+)"),
    re.compile(r"-svseed\s+(\d+)"),
    re.compile(r"random seed\D{0,16}?(\d+)", re.I),
]
COVERAGE_RE = re.compile(
    r"(?:overall|total)[^\n%]{0,80}?coverage[^\n%]{0,40}?([0-9]+(?:\.[0-9]+)?)\s*%",
    re.I)


def parse_log(log_path):
    info = {"summary_found": False, "uvm_errors": None, "uvm_fatals": None,
            "seed": None, "coverage": None}
    try:
        text = Path(log_path).read_text(errors="replace")
    except OSError:
        return info
    counts = {}
    for severity, count in UVM_COUNT_RE.findall(text):
        counts[severity] = int(count)  # the last match is the final summary
    if counts:
        info["summary_found"] = True
        info["uvm_errors"] = counts.get("ERROR")
        info["uvm_fatals"] = counts.get("FATAL")
    for regex in SEED_RES:
        match = regex.search(text)
        if match:
            info["seed"] = int(match.group(1))
            break
    for match in COVERAGE_RE.finditer(text):
        info["coverage"] = float(match.group(1))
    return info


def git_rev(directory):
    try:
        proc = subprocess.run(
            ["git", "-C", str(directory), "rev-parse", "--short", "HEAD"],
            capture_output=True, text=True, timeout=10)
        if proc.returncode == 0:
            return proc.stdout.strip()
    except Exception:
        pass
    return "unknown"


def main(argv=None):
    ap = argparse.ArgumentParser(description="append a run to verif_matrix.yaml")
    ap.add_argument("--matrix", required=True)
    ap.add_argument("--config", required=True)
    ap.add_argument("--test", required=True)
    ap.add_argument("--seed", default="")
    ap.add_argument("--log", required=True)
    ap.add_argument("--xrun-status", type=int, default=0)
    args = ap.parse_args(argv)

    try:
        cfg = cfg2args.load_config(args.config)
    except Exception as exc:
        print("record_result: %s" % exc, file=sys.stderr)
        return 2

    log_info = parse_log(args.log)
    passed = (args.xrun_status == 0
              and log_info["summary_found"]
              and log_info["uvm_errors"] == 0
              and log_info["uvm_fatals"] == 0)
    seed = log_info["seed"] if log_info["seed"] is not None else args.seed

    matrix_path = Path(args.matrix)
    env_root = matrix_path.resolve().parent
    try:
        log_ref = str(Path(args.log).resolve().relative_to(env_root))
    except ValueError:
        log_ref = args.log

    record = {
        "date": datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S"),
        "config_name": cfg2args.config_name(cfg),
        "param_hash": cfg2args.param_hash(cfg),
        "params": cfg2args.params_of(cfg),
        "test": args.test,
        "seed": str(seed),
        "status": "pass" if passed else "fail",
        "uvm_errors": log_info["uvm_errors"],
        "uvm_fatals": log_info["uvm_fatals"],
        "coverage": log_info["coverage"],
        "git_rev": git_rev(env_root),
        "log": log_ref,
    }

    matrix_path.parent.mkdir(parents=True, exist_ok=True)
    with open(matrix_path, "a+") as handle:
        if fcntl is not None:
            fcntl.flock(handle, fcntl.LOCK_EX)
        handle.seek(0)
        data = yaml.safe_load(handle.read() or "") or {}
        runs = data.get("runs") or []
        runs.append(record)
        data["runs"] = runs
        handle.seek(0)
        handle.truncate()
        handle.write(MATRIX_HEADER)
        handle.write(yaml.safe_dump(data, sort_keys=False, default_flow_style=False))
        handle.flush()
        if fcntl is not None:
            fcntl.flock(handle, fcntl.LOCK_UN)

    print("record_result: %s / %s (seed %s) -> %s  [%s]"
          % (record["config_name"], args.test, record["seed"],
             record["status"].upper(), args.matrix))
    return 0


if __name__ == "__main__":
    sys.exit(main())
