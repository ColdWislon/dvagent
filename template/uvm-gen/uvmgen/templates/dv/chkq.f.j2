# ==============================================================================
# {{ ip }} checker-qualification (chkq) compile filelist — OPT-IN.
# Generated by uvm-gen {{ gen_version }}. Never in the default build; append it
# only for negative-test runs (a deliberately corrupted DUT produces fake
# coverage, so these runs stay out of functional/coverage merges).
#
#   make -C sim compile EXTRA_FILELISTS=${{ IP }}_VERIF_HOME/dv/tests/negative/chkq.f
#   make -C sim run TEST={{ ip }}_example_neg_test \
#        EXTRA_FILELISTS=${{ IP }}_VERIF_HOME/dv/tests/negative/chkq.f \
#        XRUN_OPTS='+CHKQ_ENABLE -access +rwc'
#
# ${{ IP }}_VERIF_HOME is exported by sim/Makefile. Compiles after tb.f
# (imports {{ ip }}_test_pkg / {{ ip }}_env_pkg, already built there).
# ==============================================================================
-incdir ${{ IP }}_VERIF_HOME/dv/tests/negative
${{ IP }}_VERIF_HOME/dv/tests/negative/chkq_pkg.sv
${{ IP }}_VERIF_HOME/dv/tests/negative/{{ ip }}_chkq_pkg.sv
