// -----------------------------------------------------------------------------
// {{ ip }}_base_test — builds {{ ip }}_env from a {{ ip }}_env_cfg it owns
// Generated by uvm-gen {{ gen_version }}.
//
// This test is the STANDALONE parent of the env: it creates the config
// object, hooks the virtual interfaces the testbench published for
// uvm_test_top, applies command-line configuration overrides, and hands the
// finished cfg to the env via the config_db. An SoC env plays this role at
// SoC level — the env itself never changes.
// -----------------------------------------------------------------------------
`ifndef {{ IP }}_BASE_TEST_SV
`define {{ IP }}_BASE_TEST_SV

class {{ ip }}_base_test extends uvm_test;

  {{ ip }}_env     m_env;
  {{ ip }}_env_cfg cfg;

  `uvm_component_utils({{ ip }}_base_test)

  function new(string name = "{{ ip }}_base_test", uvm_component parent = null);
    super.new(name, parent);
  endfunction

  virtual function void build_phase(uvm_phase phase);
    super.build_phase(phase);
    cfg = {{ ip }}_env_cfg::type_id::create("cfg");
    configure_env(cfg);
    hook_virtual_interfaces(cfg);
    uvm_config_db#({{ ip }}_env_cfg)::set(this, "m_env", "cfg", cfg);
    m_env = {{ ip }}_env::type_id::create("m_env", this);
  endfunction

  // Central place for derived tests to tweak the configuration. The plusarg
  // overrides (+{{ IP }}_CFG_NAME/+{{ IP }}_PARAM/+{{ IP }}_PASSIVE/...) are applied
  // here so `make run CFG=...` selects a configuration with zero code edits.
  virtual function void configure_env({{ ip }}_env_cfg env_cfg);
    env_cfg.apply_cmdline_overrides();
  endfunction

  // Fetch the interfaces the testbench published FOR THIS TEST and store them
  // in the config object — components below never touch the config_db for vifs.
  virtual function void hook_virtual_interfaces({{ ip }}_env_cfg env_cfg);
{% for a in agents %}
    if (!uvm_config_db#(virtual {{ ip }}_{{ a.name }}_if)::get(this, "", "{{ a.name }}_vif", env_cfg.{{ a.name }}_cfg.vif))
      `uvm_fatal(get_type_name(),
        "virtual interface '{{ a.name }}_vif' not found — {{ ip }}_tb_top must publish it for uvm_test_top")
{% endfor %}
{% for v in vips %}
    // Cadence {{ v.title }} VIP '{{ v.name }}' binds its own interface — nothing to fetch here.
{% endfor %}
{% if not agents %}
    // no custom interfaces configured
{% endif %}
  endfunction

  virtual function void end_of_elaboration_phase(uvm_phase phase);
    super.end_of_elaboration_phase(phase);
    // Configuration signature banner — one per simulation, always printed
    `uvm_info("CFG_BANNER", cfg.sprint_banner(), UVM_NONE)
    uvm_top.print_topology();
  endfunction

  virtual function void report_phase(uvm_phase phase);
    uvm_report_server svr;
    super.report_phase(phase);
    svr = uvm_report_server::get_server();
    if (svr.get_severity_count(UVM_FATAL) + svr.get_severity_count(UVM_ERROR) == 0)
      `uvm_info(get_type_name(), "TEST PASSED", UVM_NONE)
    else
      `uvm_info(get_type_name(), "TEST FAILED", UVM_NONE)
  endfunction

endclass : {{ ip }}_base_test

`endif // {{ IP }}_BASE_TEST_SV
