// -----------------------------------------------------------------------------
// {{ ip }}_tb_top — testbench top: interfaces, clock/reset, DUT, UVM bootstrap
// Generated by uvm-gen {{ gen_version }}.
// -----------------------------------------------------------------------------
`ifndef {{ IP }}_TB_TOP_SV
`define {{ IP }}_TB_TOP_SV

module {{ ip }}_tb_top;

  import uvm_pkg::*;
  `include "uvm_macros.svh"
  import {{ ip }}_test_pkg::*;

  // ---------------------------------------------------------------------------
  // Clock / reset generation
  // ---------------------------------------------------------------------------
  logic clk;
  logic rst_n;

  initial begin
    clk = 1'b0;
    forever #5ns clk = ~clk;  // 100 MHz — adjust to the DUT's needs
  end

  initial begin
    rst_n = 1'b0;
    repeat (10) @(posedge clk);
    rst_n = 1'b1;
  end

  // ---------------------------------------------------------------------------
  // Interfaces
  // ---------------------------------------------------------------------------
{% for a in agents %}
  {{ ip }}_{{ a.name }}_if {{ a.name }}_if_i (.clk(clk), .rst_n(rst_n));
{% endfor %}
{% for v in vips %}
  // TODO(vip): instantiate the Cadence {{ v.title }} VIP interface for
  // '{{ v.name }}' here and hook it to the DUT (module/interface name per your
  // VIP release — see $CDN_VIP_ROOT docs).
{% endfor %}

  // ---------------------------------------------------------------------------
  // DUT — '{{ dut.module }}' from the config YAML. Ports are NOT auto-connected
  // (uvm-gen does not parse RTL).
  // ---------------------------------------------------------------------------
  {{ dut.module }} dut (
    // TODO(connect-dut): connect the DUT ports to the interfaces above, e.g.
    //   .clk        (clk),
    //   .rst_n      (rst_n),
{% for a in agents %}
    //   .{{ a.name }}_valid ({{ a.name }}_if_i.valid),
    //   .{{ a.name }}_data  ({{ a.name }}_if_i.data),
{% endfor %}
    // then prove it with `make compile`.
  );

  // ---------------------------------------------------------------------------
  // UVM bootstrap — publish every virtual interface for the test
  // (uvm_test_top). The test stores them in {{ ip }}_env_cfg; components never
  // fetch interfaces by hierarchical path.
  // ---------------------------------------------------------------------------
  initial begin
{% for a in agents %}
    uvm_config_db#(virtual {{ ip }}_{{ a.name }}_if)::set(null, "uvm_test_top", "{{ a.name }}_vif", {{ a.name }}_if_i);
{% endfor %}
    run_test();
  end

endmodule : {{ ip }}_tb_top

`endif // {{ IP }}_TB_TOP_SV
