// -----------------------------------------------------------------------------
// {{ ip }}_base_test.sv - base test: builds the env from configuration
// Generated by uvm-gen v{{ tool_version }} (IP: {{ ip }}). Never overwritten on re-run.
// -----------------------------------------------------------------------------
class {{ ip }}_base_test extends uvm_test;

  `uvm_component_utils({{ ip }}_base_test)

  {{ ip }}_env     env;
  {{ ip }}_env_cfg cfg;

  function new(string name, uvm_component parent);
    super.new(name, parent);
  endfunction

  virtual function void build_phase(uvm_phase phase);
    super.build_phase(phase);

    cfg = {{ ip }}_env_cfg::type_id::create("cfg");
    configure_env(cfg);
    // Runtime configuration selection: +CFG_NAME / +PARAM_<name> /
    // +{{ IP }}_ALL_PASSIVE (see sim/Makefile). Applied last so it can
    // override test-specific settings from configure_env().
    cfg.apply_plusargs();

    uvm_config_db #({{ ip }}_env_cfg)::set(this, "env", "cfg", cfg);
    env = {{ ip }}_env::type_id::create("env", this);
  endfunction

  // Test-specific configuration goes in overrides of this hook. The base
  // implementation plugs the virtual interfaces published by tb_top into the
  // config object - the only place the IP<->testbench binding happens.
  virtual function void configure_env({{ ip }}_env_cfg cfg);
{% for a in agents %}
    if (!uvm_config_db #(virtual {{ ip }}_{{ a.name }}_if)::get(this, "", "{{ a.name }}_vif", cfg.{{ a.name }}_cfg.vif))
      `uvm_fatal("NOVIF", "the testbench did not publish '{{ a.name }}_vif' (virtual {{ ip }}_{{ a.name }}_if) for uvm_test_top")
{% endfor %}
{% if not agents %}
    // (no custom agents - nothing to plug in)
{% endif %}
  endfunction

  virtual function void end_of_elaboration_phase(uvm_phase phase);
    super.end_of_elaboration_phase(phase);
    // Config signature banner: every simulation prints it; cfg_tool.py picks
    // it up to record the run in verif_matrix.yaml.
    cfg.print_banner();
  endfunction

  virtual function void report_phase(uvm_phase phase);
    uvm_report_server svr;
    super.report_phase(phase);
    svr = uvm_report_server::get_server();
    if (svr.get_severity_count(UVM_FATAL) + svr.get_severity_count(UVM_ERROR) == 0)
      `uvm_info("RESULT", "** UVM TEST PASSED **", UVM_NONE)
    else
      `uvm_info("RESULT", "** UVM TEST FAILED **", UVM_NONE)
  endfunction

endclass : {{ ip }}_base_test
