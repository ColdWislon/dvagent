// -----------------------------------------------------------------------------
// tb_top.sv - IP-level testbench top for {{ ip }}
// Generated by uvm-gen v{{ tool_version }} (IP: {{ ip }}). Never overwritten on re-run.
//
// SoC note: this file (and everything under tb/) is IP-standalone collateral.
// An SoC testbench provides its own top and publishes the interfaces the same
// way; the packages under agents/, env/, seq_lib/ are reused as-is.
// -----------------------------------------------------------------------------
module tb_top;

  timeunit 1ns;
  timeprecision 1ps;

  import uvm_pkg::*;
  `include "uvm_macros.svh"
  import {{ ip }}_test_pkg::*;

  // ---------------------------------------------------------------------------
  // Clock / reset generation
  // TODO: adjust period(s) and reset length; add per-interface clocks if the
  // IP has multiple clock domains.
  // ---------------------------------------------------------------------------
  parameter time CLK_PERIOD = 10ns;

  logic clk = 1'b0;
  logic rst_n;

  always #(CLK_PERIOD / 2) clk = ~clk;

  initial begin
    rst_n = 1'b0;
    repeat (10) @(posedge clk);
    rst_n = 1'b1;
    `uvm_info("TB", "reset released", UVM_LOW)
  end

  // ---------------------------------------------------------------------------
  // Interfaces
  // ---------------------------------------------------------------------------
{% for a in agents %}
  {{ ip }}_{{ a.name }}_if {{ a.name }}_if (.clk(clk), .rst_n(rst_n));
{% endfor %}
{% if not agents %}
  // (no custom agent interfaces configured)
{% endif %}
{% if vips %}

  // TODO: instantiate the Cadence VIP interfaces once the VIP is enabled
  // (see sim/vip_<protocol>.f and env/{{ ip }}_<name>_vip.sv):
{% for v in vips %}
  //   <cdn_{{ v.protocol }}_if> {{ v.name }}_if (...);  // {{ v.protocol|upper }} '{{ v.name }}' (role: {{ v.role }})
{% endfor %}
{% endif %}

  // ---------------------------------------------------------------------------
  // DUT
  // TODO: connect the DUT ports to the interfaces above (uvm-gen does no RTL
  // parsing). Until then sim/dut.f compiles the generated stub
  // (tb/{{ dut_module }}_stub.sv), which has no ports - compile and smoke test
  // stay green out of the box. When wiring the real RTL, also flip sim/dut.f
  // to the real filelist.
  // ---------------------------------------------------------------------------
  {{ dut_module }} dut (
    // TODO: .port_name ({{ '{' }}interface signals{{ '}' }})
  );

  // ---------------------------------------------------------------------------
  // Publish the virtual interfaces for the test (the test plugs them into
  // {{ ip }}_env_cfg - components only ever see the config object), then run.
  // ---------------------------------------------------------------------------
  initial begin
{% for a in agents %}
    uvm_config_db #(virtual {{ ip }}_{{ a.name }}_if)::set(null, "uvm_test_top", "{{ a.name }}_vif", {{ a.name }}_if);
{% endfor %}
    run_test();
  end

endmodule : tb_top
