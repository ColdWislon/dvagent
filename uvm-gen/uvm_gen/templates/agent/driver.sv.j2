// -----------------------------------------------------------------------------
// {{ ip }}_{{ a.name }}_driver.sv - driver for the '{{ a.name }}' agent
// Generated by uvm-gen v{{ tool_version }} (IP: {{ ip }}). Never overwritten on re-run.
// -----------------------------------------------------------------------------
class {{ ip }}_{{ a.name }}_driver extends uvm_driver #({{ ip }}_{{ a.name }}_seq_item);

  `uvm_component_utils({{ ip }}_{{ a.name }}_driver)

  {{ ip }}_{{ a.name }}_cfg cfg;
  virtual {{ ip }}_{{ a.name }}_if vif;

  function new(string name, uvm_component parent);
    super.new(name, parent);
  endfunction

  virtual function void build_phase(uvm_phase phase);
    super.build_phase(phase);
    if (cfg == null && !uvm_config_db #({{ ip }}_{{ a.name }}_cfg)::get(this, "", "cfg", cfg))
      `uvm_fatal("NOCFG", "no {{ ip }}_{{ a.name }}_cfg for this driver (set by the agent or via uvm_config_db)")
  endfunction

  virtual function void connect_phase(uvm_phase phase);
    super.connect_phase(phase);
    vif = cfg.vif;
    if (vif == null)
      `uvm_fatal("NOVIF", "{{ ip }}_{{ a.name }}_cfg.vif is null - the testbench/integrator must assign it")
  endfunction

  virtual task run_phase(uvm_phase phase);
    drive_idle();
    wait (vif.rst_n === 1'b1);
    forever begin
      seq_item_port.get_next_item(req);
      `uvm_info("DRV", {"driving ", req.convert2string()}, UVM_HIGH)
      drive_item(req);
      seq_item_port.item_done();
    end
  endtask

  // TODO: implement the real '{{ a.name }}' protocol timing here. The
  // placeholder body drives each item as a single-cycle 'valid' pulse so a
  // freshly generated environment produces visible, monitor-consistent
  // traffic (and the smoke test is provable before any TODO is filled in).
  virtual task drive_item({{ ip }}_{{ a.name }}_seq_item item);
    repeat (item.delay) @(vif.drv_cb);
    vif.drv_cb.valid <= 1'b1;
    vif.drv_cb.write <= item.write;
    vif.drv_cb.addr  <= item.addr;
    vif.drv_cb.data  <= item.data;
    @(vif.drv_cb);
    drive_idle();
  endtask

  virtual task drive_idle();
    vif.drv_cb.valid <= 1'b0;
  endtask

endclass : {{ ip }}_{{ a.name }}_driver
