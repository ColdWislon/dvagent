// Generated by uvm-gen v{{ tool_version }} (IP: {{ ip }}). Never overwritten on re-run.
// -----------------------------------------------------------------------------
class {{ ip }}_{{ a.name }}_monitor extends uvm_monitor;

  `uvm_component_utils({{ ip }}_{{ a.name }}_monitor)

  {{ ip }}_{{ a.name }}_cfg cfg;
  virtual {{ ip }}_{{ a.name }}_if vif;

  uvm_analysis_port #({{ ip }}_{{ a.name }}_seq_item) ap;

  function new(string name, uvm_component parent);
    super.new(name, parent);
  endfunction

  virtual function void build_phase(uvm_phase phase);
    super.build_phase(phase);
    ap = new("ap", this);
    if (cfg == null && !uvm_config_db #({{ ip }}_{{ a.name }}_cfg)::get(this, "", "cfg", cfg))
      `uvm_fatal("NOCFG", "no {{ ip }}_{{ a.name }}_cfg for this monitor (set by the agent or via uvm_config_db)")
  endfunction

  virtual function void connect_phase(uvm_phase phase);
    super.connect_phase(phase);
    vif = cfg.vif;
    if (vif == null)
      `uvm_fatal("NOVIF", "{{ ip }}_{{ a.name }}_cfg.vif is null - the testbench/integrator must assign it")
  endfunction

  virtual task run_phase(uvm_phase phase);
    wait (vif.rst_n === 1'b1);
    forever collect_transaction();
  endtask

  // TODO: implement real '{{ a.name }}' protocol observation (and, with
  // cfg.has_checks, protocol checks). The placeholder recognises the
  // single-cycle 'valid' pulses produced by the placeholder driver.
  virtual task collect_transaction();
    {{ ip }}_{{ a.name }}_seq_item tr;
    @(vif.mon_cb);
    if (vif.mon_cb.valid === 1'b1) begin
      tr = {{ ip }}_{{ a.name }}_seq_item::type_id::create("tr");
      tr.write = vif.mon_cb.write;
      tr.addr  = vif.mon_cb.addr;
      tr.data  = vif.mon_cb.data;
      tr.delay = 0;
      `uvm_info("MON", {"observed ", tr.convert2string()}, UVM_HIGH)
      ap.write(tr);
    end
  endtask

endclass : {{ ip }}_{{ a.name }}_monitor
