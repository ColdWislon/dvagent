// -----------------------------------------------------------------------------
// {{ ip }}_{{ v.name }}_vip.sv - Cadence {{ v.protocol|upper }} VIP instance '{{ v.name }}' (role: {{ v.role }})
// Generated by uvm-gen v{{ tool_version }} (IP: {{ ip }}). Never overwritten on re-run.
//
// Integration model:
//   * The environment compiles and runs WITHOUT the VIP installed: until
//     `{{ v.guard_define }} is defined, a compile-clean placeholder stands in
//     for the VIP agent.
//   * sim/vip_{{ v.protocol }}.f is the single place that defines
//     {{ v.guard_define }} and compiles the VIP sources from $CDN_VIP_ROOT
//     (sim/Makefile refuses to run with VIPs configured but CDN_VIP_ROOT
//     unset).
//   * Every VIP-release-specific class name lives in THIS file only - fill
//     the `ifdef blocks using the pure-UVM integration example shipped with
//     your VIP ($CDN_VIP_ROOT/.../examples).
// -----------------------------------------------------------------------------

class {{ ip }}_{{ v.name }}_vip_cfg extends uvm_object;

  `uvm_object_utils({{ ip }}_{{ v.name }}_vip_cfg)

  // Active at IP level; flipped to UVM_PASSIVE by {{ ip }}_env_cfg::set_all_passive()
  // for SoC integration (VIP monitors only).
  uvm_active_passive_enum is_active = {{ v.uvm_active }};

  // Instance role: {{ v.roles_str }}.
  string role = "{{ v.role }}";
{% if v.protocol == 'i3c' %}

  // MIPI I3C defaults chosen by uvm-gen - edit to taste.
  bit          ibi_enable      = {{ v.ibi_enable_bit }};  // In-Band Interrupts
  bit          hot_join_enable = 0;
  bit [6:0]    static_addr     = 7'h30;
{% elif v.protocol == 'ahb' %}

  // AHB defaults chosen by uvm-gen - edit to taste.
  int unsigned hburst_max = 8;   // longest burst the stimulus may generate
{% elif v.protocol == 'apb' %}

  // APB defaults chosen by uvm-gen - edit to taste.
  bit has_pslverr = 1;
{% endif %}

`ifdef {{ v.guard_define }}
  // TODO: declare + create the Cadence {{ v.protocol|upper }} VIP configuration here and
  // map the knobs above onto it (class names come from your VIP release), e.g.:
  //   cdn_{{ v.protocol }}_uvm_user_config vip_cfg;
`endif

  function new(string name = "{{ ip }}_{{ v.name }}_vip_cfg");
    super.new(name);
  endfunction

endclass : {{ ip }}_{{ v.name }}_vip_cfg


class {{ ip }}_{{ v.name }}_vip extends uvm_component;

  `uvm_component_utils({{ ip }}_{{ v.name }}_vip)

  {{ ip }}_{{ v.name }}_vip_cfg cfg;

  // Generic hook the rest of the env connects to ({{ ip }}_vsequencer.{{ v.name }}_sqr).
  // Stays null until the real VIP publishes its sequencer below.
  uvm_sequencer_base sqr;

`ifdef {{ v.guard_define }}
  // TODO: declare the Cadence {{ v.protocol|upper }} VIP agent/env, e.g.:
  //   cdn_{{ v.protocol }}_uvm_agent m_agent;
`endif

  function new(string name, uvm_component parent);
    super.new(name, parent);
  endfunction

  virtual function void build_phase(uvm_phase phase);
    super.build_phase(phase);
    if (cfg == null && !uvm_config_db #({{ ip }}_{{ v.name }}_vip_cfg)::get(this, "", "cfg", cfg))
      `uvm_fatal("NOCFG", "no {{ ip }}_{{ v.name }}_vip_cfg for this VIP wrapper (set by the env)")
`ifdef {{ v.guard_define }}
    // TODO: create + configure the VIP agent from cfg (role={{ v.role }},
    // is_active, protocol knobs), e.g.:
    //   m_agent = cdn_{{ v.protocol }}_uvm_agent::type_id::create("m_agent", this);
`else
    `uvm_info("VIP", {"Cadence {{ v.protocol|upper }} VIP for '", get_name(),
              "' not compiled in (placeholder active). Enable it via ",
              "sim/vip_{{ v.protocol }}.f (+define+{{ v.guard_define }} + VIP filelist)."},
              UVM_LOW)
`endif
  endfunction

  virtual function void connect_phase(uvm_phase phase);
    super.connect_phase(phase);
`ifdef {{ v.guard_define }}
    // TODO: publish the VIP sequencer and analysis connections, e.g.:
    //   sqr = m_agent.sequencer;
    //   m_agent.monitor.analysis_port.connect(<scoreboard imp / coverage>);
`endif
  endfunction

endclass : {{ ip }}_{{ v.name }}_vip
