// -----------------------------------------------------------------------------
// {{ ip }}_{{ a.name }}_cov.sv - functional coverage subscriber ('{{ a.name }}')
// Generated by uvm-gen v{{ tool_version }} (IP: {{ ip }}). Never overwritten on re-run.
// Connected to the '{{ a.name }}' monitor analysis stream by {{ ip }}_env.
// -----------------------------------------------------------------------------
class {{ ip }}_{{ a.name }}_cov extends uvm_subscriber #({{ ip }}_{{ a.name }}_seq_item);

  `uvm_component_utils({{ ip }}_{{ a.name }}_cov)

  {{ ip }}_env_cfg cfg;

  {{ ip }}_{{ a.name }}_seq_item item;

  // TODO: replace this example covergroup with real '{{ a.name }}' protocol
  // coverage. Parameter fields in {{ ip }}_env_cfg (e.g. widths/depths of the
  // active configuration) can shape bins so coverage adapts per config.
  // Tag every real bin with its vplan item (// VP-xxx) - coverage without
  // traceability does not count as evidence.
  covergroup {{ a.name }}_cg;
    option.per_instance = 1;
    cp_direction : coverpoint item.write {
      bins read  = {0};
      bins write = {1};
    }
    cp_addr : coverpoint item.addr {
      bins lo  = {[32'h0000_0000 : 32'h0000_FFFF]};
      bins mid = {[32'h0001_0000 : 32'h7FFF_FFFF]};
      bins hi  = {[32'h8000_0000 : 32'hFFFF_FFFF]};
    }
    x_direction_addr : cross cp_direction, cp_addr;
  endgroup

  function new(string name, uvm_component parent);
    super.new(name, parent);
    {{ a.name }}_cg = new();
  endfunction

  virtual function void write({{ ip }}_{{ a.name }}_seq_item t);
    item = t;
    {{ a.name }}_cg.sample();
  endfunction

endclass : {{ ip }}_{{ a.name }}_cov
