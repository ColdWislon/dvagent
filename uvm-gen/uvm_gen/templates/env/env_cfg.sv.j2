// -----------------------------------------------------------------------------
// {{ ip }}_env_cfg.sv - single configuration object for {{ ip }}_env
// Generated by uvm-gen v{{ tool_version }} (IP: {{ ip }}). Never overwritten on re-run.
//
// Vertical-reuse contract: this is the ONE object a test (IP level) or an SoC
// env (SoC level) builds and publishes via uvm_config_db. It carries every
// agent/VIP config, all virtual interfaces, the RAL knobs and the RTL/DV
// parameters - components never reach outside it.
// -----------------------------------------------------------------------------
class {{ ip }}_env_cfg extends uvm_object;

  `uvm_object_utils({{ ip }}_env_cfg)

  // --------------------------------------------------------------------------
  // Configuration identity (multi-configuration IP support)
  // --------------------------------------------------------------------------
  string config_name = "{{ config_name }}";

  // RTL/DV parameters. Defaults come from the YAML this env was generated
  // from; runtime values arrive per configuration via +PARAM_<name>=
  // plusargs (driven by sim/Makefile from the CFG= YAML). Use these fields to
  // adapt env behavior and coverage per configuration.
{% for p in params %}
  {{ p.sv_decl }}
{% endfor %}
{% if not params %}
  // (no params declared in the configuration YAML)
{% endif %}

  // --------------------------------------------------------------------------
  // Environment knobs
  // --------------------------------------------------------------------------
  bit has_scoreboard = 1;
  bit has_coverage   = 1;

  // --------------------------------------------------------------------------
  // RAL
  // --------------------------------------------------------------------------
  bit enable_ral = 1;
  // 1: this env owns the register bus - adapter, predictor and map sequencer
  //    are wired (IP standalone).
  // 0: SoC level - the SoC owns the bus; only the model is used here.
  bit ral_env_owns_bus = 1;
  // Base address used when the env builds its own model (standalone). When
  // the model comes from above, the SoC's add_submap() offset applies instead.
  uvm_reg_addr_t ral_base_addr = 'h0;
  // Optionally set from above (SoC): a pre-built {{ ip }}_reg_block already
  // integrated as a child of the SoC register model. Left null, the env
  // creates and builds its own.
  {{ ip }}_reg_block regmodel;

  // --------------------------------------------------------------------------
  // Agent / VIP configurations (virtual interfaces live inside these)
  // --------------------------------------------------------------------------
{% for a in agents %}
  {{ ip }}_{{ a.name }}_cfg {{ a.name }}_cfg;
{% endfor %}
{% for v in vips %}
  {{ ip }}_{{ v.name }}_vip_cfg {{ v.name }}_cfg;
{% endfor %}

  function new(string name = "{{ ip }}_env_cfg");
    super.new(name);
{% for a in agents %}
    {{ a.name }}_cfg = {{ ip }}_{{ a.name }}_cfg::type_id::create("{{ a.name }}_cfg");
{% endfor %}
{% for v in vips %}
    {{ v.name }}_cfg = {{ ip }}_{{ v.name }}_vip_cfg::type_id::create("{{ v.name }}_cfg");
{% endfor %}
  endfunction

  // Flip every agent/VIP to passive: SoC-integration mode. RTL drives the
  // buses; monitors, scoreboard and coverage stay live. No source edits.
  virtual function void set_all_passive();
{% for a in agents %}
    {{ a.name }}_cfg.is_active = UVM_PASSIVE;
{% endfor %}
{% for v in vips %}
    {{ v.name }}_cfg.is_active = UVM_PASSIVE;
{% endfor %}
  endfunction

  virtual function void set_all_active();
{% for a in agents %}
    {{ a.name }}_cfg.is_active = UVM_ACTIVE;
{% endfor %}
{% for v in vips %}
    {{ v.name }}_cfg.is_active = UVM_ACTIVE;
{% endfor %}
  endfunction

  // Runtime configuration selection (see sim/Makefile):
  //   +CFG_NAME=<name>  +PARAM_<param>=<value>  +{{ IP }}_ALL_PASSIVE
  virtual function void apply_plusargs();
    void'($value$plusargs("CFG_NAME=%s", config_name));
{% for p in params %}
    void'($value$plusargs("PARAM_{{ p.name }}={{ p.plusarg_fmt }}", {{ p.name }}));
{% endfor %}
    if ($test$plusargs("{{ IP }}_ALL_PASSIVE"))
      set_all_passive();
  endfunction

  // Canonical "name=value,..." list of the full parameter set, sorted by
  // name. Must stay in sync with sim/scripts/cfg_tool.py (Python twin).
  virtual function string params_canonical();
    string s = "";
{% for p in params %}
    s = {s, $sformatf("{% if not loop.first %},{% endif %}{{ p.name }}={{ p.fmt }}", {{ p.name }})};
{% endfor %}
    return s;
  endfunction

  // FNV-1a 32-bit hash of the canonical parameter set: the short config
  // signature printed in the banner and recorded in verif_matrix.yaml.
  virtual function int unsigned param_hash();
    string s = params_canonical();
    int unsigned h = 32'h811c_9dc5;
    foreach (s[i]) begin
      h = h ^ s[i];
      h = h * 32'h0100_0193;
    end
    return h;
  endfunction

  // Configuration signature banner: printed by every simulation (from
  // {{ ip }}_base_test), one greppable fact per line - parsed by
  // sim/scripts/cfg_tool.py into verif_matrix.yaml.
  virtual function void print_banner();
    `uvm_info("UVM_GEN_CFG", "------------------------------------------------------------", UVM_NONE)
    `uvm_info("UVM_GEN_CFG", "ip          : {{ ip }}", UVM_NONE)
    `uvm_info("UVM_GEN_CFG", $sformatf("config_name : %s", config_name), UVM_NONE)
    `uvm_info("UVM_GEN_CFG", $sformatf("param_hash  : 0x%08h", param_hash()), UVM_NONE)
{% for p in params %}
    `uvm_info("UVM_GEN_CFG", $sformatf("param {{ p.name }} = {{ p.fmt }}", {{ p.name }}), UVM_NONE)
{% endfor %}
    `uvm_info("UVM_GEN_CFG", "------------------------------------------------------------", UVM_NONE)
  endfunction

endclass : {{ ip }}_env_cfg
