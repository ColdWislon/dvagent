package {{ ip }}_env_pkg;

  import uvm_pkg::*;
  `include "uvm_macros.svh"

{% for a in agents %}
  import {{ ip }}_{{ a.name }}_agent_pkg::*;
{% endfor %}

  `include "{{ ip }}_reg_block.sv"
{% if first_agent %}
  `include "{{ ip }}_reg_adapter.sv"
{% endif %}
{% for v in vips %}
  `include "{{ ip }}_{{ v.name }}_vip.sv"
{% endfor %}
  `include "{{ ip }}_env_cfg.sv"
  `include "{{ ip }}_scoreboard.sv"
{% for a in agents %}
  `include "{{ ip }}_{{ a.name }}_cov.sv"
{% endfor %}
  `include "{{ ip }}_vsequencer.sv"
  `include "{{ ip }}_env.sv"

endpackage : {{ ip }}_env_pkg
