// -----------------------------------------------------------------------------
// {{ ip }}_env.sv - top-level environment for {{ ip }}
// Generated by uvm-gen v{{ tool_version }} (IP: {{ ip }}). Never overwritten on re-run.
//
// Vertical reuse: this env drops into an SoC environment unmodified. It is
// configured exclusively through ONE {{ ip }}_env_cfg retrieved via
// uvm_config_db (set by the IP test or by the SoC env); it never references
// tb_top or absolute hierarchy.
// -----------------------------------------------------------------------------
class {{ ip }}_env extends uvm_env;

  `uvm_component_utils({{ ip }}_env)

  {{ ip }}_env_cfg cfg;

{% for a in agents %}
  {{ ip }}_{{ a.name }}_agent {{ a.name }}_agent;
{% endfor %}
{% for a in agents %}
  {{ ip }}_{{ a.name }}_cov {{ a.name }}_cov;
{% endfor %}
{% for v in vips %}
  {{ ip }}_{{ v.name }}_vip {{ v.name }}_vip;
{% endfor %}
  {{ ip }}_scoreboard scoreboard;
  {{ ip }}_vsequencer vsequencer;
{% if first_agent %}

  // RAL machinery - built only when this env owns the register bus.
  {{ ip }}_reg_adapter reg_adapter;
  uvm_reg_predictor #({{ ip }}_{{ first_agent }}_seq_item) reg_predictor;
{% endif %}

  function new(string name, uvm_component parent);
    super.new(name, parent);
  endfunction

  virtual function void build_phase(uvm_phase phase);
    super.build_phase(phase);

    // The single configuration object, provided from above (IP test or SoC
    // env). Everything - virtual interfaces included - travels inside it.
    if (cfg == null && !uvm_config_db #({{ ip }}_env_cfg)::get(this, "", "cfg", cfg))
      `uvm_fatal("NOCFG", {"no {{ ip }}_env_cfg provided for '", get_full_name(),
                 "' - publish one with uvm_config_db #({{ ip }}_env_cfg)::set()"})

{% for a in agents %}
    {{ a.name }}_agent     = {{ ip }}_{{ a.name }}_agent::type_id::create("{{ a.name }}_agent", this);
    {{ a.name }}_agent.cfg = cfg.{{ a.name }}_cfg;
{% endfor %}
{% for v in vips %}
    {{ v.name }}_vip     = {{ ip }}_{{ v.name }}_vip::type_id::create("{{ v.name }}_vip", this);
    {{ v.name }}_vip.cfg = cfg.{{ v.name }}_cfg;
{% endfor %}

    if (cfg.has_scoreboard) begin
      scoreboard     = {{ ip }}_scoreboard::type_id::create("scoreboard", this);
      scoreboard.cfg = cfg;
    end

{% for a in agents %}
    if (cfg.has_coverage && cfg.{{ a.name }}_cfg.has_coverage) begin
      {{ a.name }}_cov     = {{ ip }}_{{ a.name }}_cov::type_id::create("{{ a.name }}_cov", this);
      {{ a.name }}_cov.cfg = cfg;
    end
{% endfor %}

    vsequencer     = {{ ip }}_vsequencer::type_id::create("vsequencer", this);
    vsequencer.cfg = cfg;

    if (cfg.enable_ral) begin
      if (cfg.regmodel == null) begin
        // Standalone (IP level): build our own register model. At SoC level
        // the SoC builds the full model, adds {{ ip }}_reg_block as a child
        // with an add_submap() offset, and passes it in via cfg.regmodel.
        cfg.regmodel = {{ ip }}_reg_block::type_id::create("regmodel");
        cfg.regmodel.build();
        cfg.regmodel.default_map.set_base_addr(cfg.ral_base_addr);
      end
{% if first_agent %}
      if (cfg.ral_env_owns_bus) begin
        reg_adapter   = {{ ip }}_reg_adapter::type_id::create("reg_adapter");
        reg_predictor = uvm_reg_predictor #({{ ip }}_{{ first_agent }}_seq_item)::type_id::create("reg_predictor", this);
      end
{% else %}
      // TODO: no custom agent exists to carry register traffic - wire the
      // adapter/predictor to the owning VIP once it is integrated.
{% endif %}
    end
  endfunction

  virtual function void connect_phase(uvm_phase phase);
    super.connect_phase(phase);

{% for a in agents %}
    // '{{ a.name }}' analysis fan-out: scoreboard + coverage.
    if (scoreboard != null)
      {{ a.name }}_agent.ap.connect(scoreboard.{{ a.name }}_imp);
    if ({{ a.name }}_cov != null)
      {{ a.name }}_agent.ap.connect({{ a.name }}_cov.analysis_export);
    vsequencer.{{ a.name }}_sqr = (cfg.{{ a.name }}_cfg.is_active == UVM_ACTIVE)
                                  ? {{ a.name }}_agent.m_sequencer : null;
{% endfor %}
{% for v in vips %}
    vsequencer.{{ v.name }}_sqr = {{ v.name }}_vip.sqr;
{% endfor %}
{% if first_agent %}

    // RAL plumbing - only when this env owns the register bus (IP level).
    // At SoC level (ral_env_owns_bus == 0) the SoC's predictor/adapter and
    // map sequencer take over; the model itself still works from cfg.regmodel.
    if (cfg.enable_ral && cfg.ral_env_owns_bus) begin
      reg_predictor.map     = cfg.regmodel.default_map;
      reg_predictor.adapter = reg_adapter;
      {{ first_agent }}_agent.ap.connect(reg_predictor.bus_in);
      cfg.regmodel.default_map.set_auto_predict(0);
      if (cfg.{{ first_agent }}_cfg.is_active == UVM_ACTIVE)
        cfg.regmodel.default_map.set_sequencer({{ first_agent }}_agent.m_sequencer, reg_adapter);
    end
{% endif %}
  endfunction

endclass : {{ ip }}_env
