# -----------------------------------------------------------------------------
# Makefile - Xcelium simulation flow for {{ ip }} (generated by uvm-gen v{{ tool_version }})
# Never overwritten on re-run (--force regenerates).
#
# Single-step xrun with the Xcelium-bundled UVM-1.2 (-uvmhome CDNS-1.2).
# Xcelium only - no other simulators are supported.
#
# Common invocations (from this directory):
#   make compile                                  # elaborate-only sanity
#   make run TEST={{ ip }}_smoke_test [SEED=n]
#   make run TEST={{ ip }}_smoke_test CFG=../cfg/<config>.yaml
#   make run TEST={{ ip }}_smoke_test PASSIVE=1   # all agents passive (SoC mode)
#   make waves TEST={{ ip }}_smoke_test           # -access +rwc + SHM probing
#   make regress [CFG=...]                        # vManager: launch the vsif
#   make matrix                                   # config verification summary
#   make clean
# -----------------------------------------------------------------------------

IP     := {{ ip }}
TB_TOP := tb_top
PYTHON ?= python3

# Active configuration YAML (multi-configuration IP support). Paths may be
# relative to this directory or to the {{ ip }}_verif root.
CFG ?= ../cfg/{{ input_basename }}

TEST      ?= {{ ip }}_smoke_test
SEED      ?= 1
VERBOSITY ?= UVM_MEDIUM

# Extra xrun options / UVM plusargs - append at will (also from the command
# line, e.g. make run XRUN_OPTS='-linedebug').
XRUN_OPTS ?=
PLUSARGS  ?=

# -----------------------------------------------------------------------------
# Configuration-derived settings. scripts/cfg_tool.py resolves the 'extends'
# chain of $(CFG) and emits: CONFIG_NAME, PARAM_XRUN_ARGS (+define+/-defparam),
# PARAM_PLUSARGS (+PARAM_<name>=...), VIP_PROTOCOLS.
# -----------------------------------------------------------------------------
CFG_MK := .uvm_gen_cfg.mk
CFG_OK := $(shell $(PYTHON) scripts/cfg_tool.py makevars "$(CFG)" --out $(CFG_MK) && echo OK)
ifeq ($(CFG_OK),OK)
include $(CFG_MK)
else
ifeq ($(filter-out clean help matrix,$(MAKECMDGOALS)),)
CONFIG_NAME := unknown
else
$(error uvm-gen: could not parse configuration '$(CFG)' (see message above))
endif
endif

# -----------------------------------------------------------------------------
# Cadence VIP: CDN_VIP_ROOT is the single Makefile-level edit point for the
# VIP installation path (the per-protocol sim/vip_<protocol>.f files reference
# it as $CDN_VIP_ROOT). The flow refuses to run when the configuration
# requests VIPs but the variable is unset.
# -----------------------------------------------------------------------------
# (gate only simulation goals - help/clean/matrix stay usable without it)
ifneq ($(filter-out clean help matrix,$(MAKECMDGOALS)),)
ifneq ($(strip $(VIP_PROTOCOLS)),)
ifeq ($(strip $(CDN_VIP_ROOT)),)
$(error configuration '$(CONFIG_NAME)' requests Cadence VIP protocol(s): $(VIP_PROTOCOLS). Set CDN_VIP_ROOT to your Cadence VIP installation root, e.g. 'export CDN_VIP_ROOT=/tools/cadence/vipcat' (paths are consumed in sim/vip_<protocol>.f - one edit point per protocol))
endif
endif
endif
export CDN_VIP_ROOT

# -----------------------------------------------------------------------------
# Filelists: one .f per domain, each passed to xrun as its own -f (never
# merged). Design first, then DV. Append extra domains (memory models, SoC
# glue, ...) to FILELISTS without touching the rules, e.g.:
#   make run FILELISTS+='-f soc_glue.f'
# -----------------------------------------------------------------------------
DUT_F ?= dut.f
TB_F  ?= tb.f
FILELISTS ?= -f $(DUT_F) -f $(TB_F){% for proto in vip_protocols %} -f vip_{{ proto }}.f{% endfor %}

# -----------------------------------------------------------------------------
# xrun (single step: compile + elaborate + simulate)
# -----------------------------------------------------------------------------
XRUN      ?= xrun
TIMESCALE ?= 1ns/1ps
# Per-configuration work library; regression runs override this per run
# (see the vsif) so parallel compiles never collide.
XMLIBDIR  ?= xcelium.d_$(CONFIG_NAME)
LOGDIR    := logs
LOG       ?= $(LOGDIR)/$(TEST)_$(CONFIG_NAME)_s$(SEED).log

XRUN_BASE := $(XRUN) -uvmhome CDNS-1.2 -timescale $(TIMESCALE) \
             -xmlibdirname $(XMLIBDIR) \
             $(FILELISTS) \
             $(PARAM_XRUN_ARGS) \
             -top $(TB_TOP) $(XRUN_OPTS)

RUN_ARGS := -svseed $(SEED) \
            +UVM_TESTNAME=$(TEST) +UVM_VERBOSITY=$(VERBOSITY) +UVM_NO_RELNOTES \
            +CFG_NAME=$(CONFIG_NAME) $(PARAM_PLUSARGS) $(PLUSARGS)

# make run PASSIVE=1: flip every agent/VIP to passive via {{ ip }}_env_cfg -
# the SoC-reuse readiness check (no source edits involved).
ifneq ($(strip $(PASSIVE)),)
RUN_ARGS += +{{ IP }}_ALL_PASSIVE
endif

MATRIX := ../verif_matrix.yaml

COLLECT = $(PYTHON) scripts/cfg_tool.py collect "$(CFG)" --log "$(LOG)" \
          --test $(TEST) --seed "$(SEED)" --matrix $(MATRIX)

.PHONY: help compile run waves regress matrix clean
.DEFAULT_GOAL := help

help:
	@echo "uvm-gen simulation flow for {{ ip }} (configuration: $(CONFIG_NAME))"
	@echo ""
	@echo "  make compile                    elaborate-only sanity check"
	@echo "  make run TEST=<t> [SEED=n]      run one test (records to verif_matrix.yaml)"
	@echo "  make waves TEST=<t>             run with -access +rwc and SHM probing"
	@echo "  make run ... CFG=<cfg.yaml>     select a configuration"
	@echo "  make run ... PASSIVE=1          all agents passive via {{ ip }}_env_cfg"
	@echo "  make regress                    launch $(IP)_$(CONFIG_NAME).vsif via vManager"
	@echo "  make matrix                     configuration verification summary"
	@echo "  make clean"

compile: | $(LOGDIR)
	$(XRUN_BASE) -elaborate -l $(LOGDIR)/compile_$(CONFIG_NAME).log

run: | $(LOGDIR)
	-$(XRUN_BASE) $(RUN_ARGS) -l $(LOG)
	$(COLLECT)

waves: | $(LOGDIR)
	-$(XRUN_BASE) $(RUN_ARGS) -access +rwc -input probe.tcl -l $(LOG)
	$(COLLECT)

$(LOGDIR):
	mkdir -p $(LOGDIR)

# -----------------------------------------------------------------------------
# Regression: one vsif per configuration (vManager format), session
# $(IP)_$(CONFIG_NAME). The vsif reuses 'make run' so vManager runs and
# interactive runs share a single source of truth for the xrun invocation.
# Adapt REGRESS_CMD to your site's vManager setup if needed
# (e.g. vmanager -server <host:port> -execcmd "launch $(VSIF)").
# -----------------------------------------------------------------------------
VSIF        ?= $(IP)_$(CONFIG_NAME).vsif
VMANAGER    ?= vmanager
REGRESS_CMD ?= $(VMANAGER) -execcmd "launch $(VSIF)"

regress:
	@test -f "$(VSIF)" || { echo "uvm-gen: $(VSIF) not found - run uvm_gen.py with this configuration YAML to create it"; exit 1; }
	UVM_GEN_SIM_DIR=$(CURDIR) $(REGRESS_CMD)

matrix:
	@$(PYTHON) scripts/cfg_tool.py matrix $(MATRIX)

clean:
	rm -rf xcelium.d* logs waves.shm .uvm_gen_cfg.mk xrun.history xrun.log \
	       .simvision *.diag *.key bpad*.err mapped vm_sessions
