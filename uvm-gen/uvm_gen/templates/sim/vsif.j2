// -----------------------------------------------------------------------------
// {{ ip }}_{{ config_name }}.vsif - vManager regression for IP '{{ ip }}',
// configuration '{{ config_name }}' (generated by uvm-gen v{{ tool_version }}).
//
// One vsif per configuration; session name: {{ ip }}_{{ config_name }}.
// Launch from sim/ (exports UVM_GEN_SIM_DIR for the run scripts):
//   make regress CFG=../cfg/{{ input_basename }}
// or by hand:
//   UVM_GEN_SIM_DIR=$PWD vmanager -execcmd "launch {{ ip }}_{{ config_name }}.vsif"
//
// Every run goes through 'make run', so vManager runs and interactive runs
// share ONE source of truth for the xrun invocation, every run prints the
// config signature banner, and every run appends its record to
// verif_matrix.yaml. Pass/fail = run_script exit status (cfg_tool.py exits
// non-zero on UVM_ERROR/UVM_FATAL or a missing UVM report summary).
//
// Notes:
//  * XMLIBDIR is pointed into the per-run scratch area ($ENV(BRUN_RUN_DIR))
//    so parallel xrun compiles never collide on one work library.
//  * If your vManager version does not expand $ATTR(sv_seed) in run_script,
//    use SEED=random instead (xrun picks the seed; cfg_tool records it from
//    the log).
// -----------------------------------------------------------------------------

session {{ ip }}_{{ config_name }} {
    top_dir : $ENV(PWD)/vm_sessions;
    output_mode : log_only;
};

group smoke {
    test {{ ip }}_smoke_test {
        run_script : "make -C $ENV(UVM_GEN_SIM_DIR) run TEST={{ ip }}_smoke_test CFG=../cfg/{{ input_basename }} SEED=$ATTR(sv_seed) XMLIBDIR=$ENV(BRUN_RUN_DIR)/xcelium.d";
        count : 1;
        sv_seed : random;
    };
};

