# -----------------------------------------------------------------------------
# tb.f - generated DV collateral for {{ ip }}, in compile order (own -f domain)
# Generated by uvm-gen v{{ tool_version }}. Never overwritten on re-run.
#
# SoC reuse: everything except the final tb_top line is IP-agnostic collateral
# (packages + interfaces). An SoC testbench includes this file and provides
# its own top, or lifts these lines into its own DV filelist.
# -----------------------------------------------------------------------------
{% for a in agents %}
+incdir+../agents/{{ a.name }}_agent
{% endfor %}
+incdir+../env
+incdir+../seq_lib
+incdir+../tests

# interfaces
{% for a in agents %}
../agents/{{ a.name }}_agent/{{ ip }}_{{ a.name }}_if.sv
{% endfor %}

# packages (dependency order: agents -> env -> sequences -> tests)
{% for a in agents %}
../agents/{{ a.name }}_agent/{{ ip }}_{{ a.name }}_agent_pkg.sv
{% endfor %}
../env/{{ ip }}_env_pkg.sv
../seq_lib/{{ ip }}_seq_pkg.sv
../tests/{{ ip }}_test_pkg.sv

# IP-level testbench top (drop this line for SoC reuse)
../tb/tb_top.sv
