// -----------------------------------------------------------------------------
// {{ ip }}_smoke_vseq.sv - trivial virtual sequence for the smoke test
// Generated by uvm-gen v{{ tool_version }} (IP: {{ ip }}). Never overwritten on re-run.
//
// A few transactions on every ACTIVE interface, in parallel. Passive
// interfaces (SoC integration: sequencer handle is null) are skipped
// automatically - same sequence, no code edits.
// -----------------------------------------------------------------------------
class {{ ip }}_smoke_vseq extends {{ ip }}_base_vseq;

  `uvm_object_utils({{ ip }}_smoke_vseq)

  rand int unsigned items_per_agent = 4;

  constraint c_items { items_per_agent inside {[2:8]}; }

  function new(string name = "{{ ip }}_smoke_vseq");
    super.new(name);
  endfunction

  virtual task body();
{% if agents %}
    fork
{% for a in agents %}
      begin
        if (p_sequencer.{{ a.name }}_sqr != null) begin
          {{ ip }}_{{ a.name }}_base_seq seq;
          seq = {{ ip }}_{{ a.name }}_base_seq::type_id::create("{{ a.name }}_seq");
          if (!seq.randomize() with { num_items == local::items_per_agent; })
            `uvm_error("RNDFAIL", "'{{ a.name }}' sequence randomization failed")
          seq.start(p_sequencer.{{ a.name }}_sqr, this);
        end
        else begin
          `uvm_info("SMOKE", "'{{ a.name }}' is passive - no stimulus sent", UVM_LOW)
        end
      end
{% endfor %}
    join
{% else %}
    `uvm_info("SMOKE", "no custom agents in this environment - nothing to drive", UVM_LOW)
{% endif %}
{% if vips %}
    // TODO: start Cadence VIP sequences on the VIP sequencers once integrated:
{% for v in vips %}
    //   p_sequencer.{{ v.name }}_sqr  ({{ v.protocol|upper }} '{{ v.name }}', role {{ v.role }})
{% endfor %}
{% endif %}
  endtask

endclass : {{ ip }}_smoke_vseq
