#!/usr/bin/env python3
"""cfg2args.py — turn a {{ ip }} configuration YAML into sim/Makefile inputs.

Generated by uvm-gen {{ gen_version }}; self-contained (Python 3 + PyYAML).
The 'extends' deep-merge (config file wins) and the parameter hash are
IDENTICAL to the generator's, so banners, verif_matrix records and future
re-generations always agree.
"""

import argparse
import hashlib
import json
import os
import sys
from pathlib import Path

import yaml

IP = "{{ ip }}"
IP_UPPER = "{{ IP }}"


def deep_merge(base, override):
    """Recursive dict merge; the override (config file) wins. Lists replace."""
    if isinstance(base, dict) and isinstance(override, dict):
        merged = dict(base)
        for key, value in override.items():
            merged[key] = deep_merge(base[key], value) if key in base else value
        return merged
    return override


def load_config(path, _stack=()):
    """Load a YAML config resolving 'extends' chains (deep-merge, child wins)."""
    path = Path(path).resolve()
    if path in _stack:
        raise ValueError("circular 'extends' chain at %s" % path)
    if not path.is_file():
        raise ValueError("config file not found: %s" % path)
    data = yaml.safe_load(path.read_text()) or {}
    if not isinstance(data, dict):
        raise ValueError("%s: top level must be a YAML mapping" % path)
    extends = data.pop("extends", None)
    if extends is not None:
        base = load_config(path.parent / str(extends), _stack + (path,))
        data = deep_merge(base, data)
    return data


def _norm_scalar(value):
    return int(value) if isinstance(value, bool) else value


def params_of(cfg):
    return {str(k): _norm_scalar(v) for k, v in (cfg.get("params") or {}).items()}


def defines_of(cfg):
    return {str(k): _norm_scalar(v) for k, v in (cfg.get("defines") or {}).items()}


def param_hash(cfg):
    """Short, stable hash over the parameter set — matches the generator."""
    blob = json.dumps(
        {"params": params_of(cfg), "defines": defines_of(cfg),
         "param_style": cfg.get("param_style", "define")},
        sort_keys=True, default=str)
    return hashlib.sha256(blob.encode()).hexdigest()[:8]


def config_name(cfg):
    return str(cfg.get("config_name", "default"))


def vsif_name(cfg):
    name = config_name(cfg)
    if name == "default":
        return "%s.vsif" % IP
    return "%s_%s.vsif" % (IP, name)


def xrun_args(cfg, tb_top):
    """RTL parameters/defines -> xrun flags, plus the env plusargs."""
    args = []
    style = cfg.get("param_style", "define")
    for key, value in sorted(params_of(cfg).items()):
        if style == "defparam":
            args.append("-defparam %s.dut.%s=%s" % (tb_top, key, value))
        else:
            args.append("+define+%s=%s" % (key, value))
    for key, value in sorted(defines_of(cfg).items()):
        args.append("+define+%s=%s" % (key, value))
    args.append("+%s_CFG_NAME=%s" % (IP_UPPER, config_name(cfg)))
    args.append("+%s_CFG_HASH=%s" % (IP_UPPER, param_hash(cfg)))
    for key, value in sorted(params_of(cfg).items()):
        args.append("+%s_PARAM=%s=%s" % (IP_UPPER, key, value))
    return " ".join(args)


def dut_filelist(cfg, cfg_path):
    """Absolute path of the DUT RTL filelist ('' when not configured).

    Relative paths resolve against the directory containing the config file;
    environment variables ($PROJ_ROOT/...) are expanded.
    """
    raw = (cfg.get("dut") or {}).get("rtl_filelist")
    if not raw:
        return ""
    raw = os.path.expandvars(str(raw))
    p = Path(raw)
    if p.is_absolute():
        return str(p)
    return str((Path(cfg_path).resolve().parent / p).resolve())


def vip_protocols(cfg):
    seen = []
    for vip in cfg.get("vips") or []:
        proto = vip.get("protocol")
        if proto and proto not in seen:
            seen.append(proto)
    return seen


def main(argv=None):
    ap = argparse.ArgumentParser(
        description="emit {{ ip }} Makefile inputs from a config YAML")
    ap.add_argument("config", help="configuration YAML (supports 'extends')")
    ap.add_argument("--tb-top", default="%s_tb_top" % IP,
                    help="testbench top module (for -defparam paths)")
    group = ap.add_mutually_exclusive_group(required=True)
    group.add_argument("--config-name", action="store_true")
    group.add_argument("--param-hash", action="store_true")
    group.add_argument("--xrun-args", action="store_true")
    group.add_argument("--dut-filelist", action="store_true")
    group.add_argument("--has-vips", action="store_true")
    group.add_argument("--vip-protocols", action="store_true")
    group.add_argument("--vsif-name", action="store_true")
    group.add_argument("--params-json", action="store_true")
    args = ap.parse_args(argv)

    try:
        cfg = load_config(args.config)
    except Exception as exc:
        print("cfg2args: %s" % exc, file=sys.stderr)
        return 2

    if args.config_name:
        print(config_name(cfg))
    elif args.param_hash:
        print(param_hash(cfg))
    elif args.xrun_args:
        print(xrun_args(cfg, args.tb_top))
    elif args.dut_filelist:
        print(dut_filelist(cfg, args.config))
    elif args.has_vips:
        print(1 if (cfg.get("vips") or []) else 0)
    elif args.vip_protocols:
        print(" ".join(vip_protocols(cfg)))
    elif args.vsif_name:
        print(vsif_name(cfg))
    elif args.params_json:
        print(json.dumps({"params": params_of(cfg), "defines": defines_of(cfg)},
                         sort_keys=True))
    return 0


if __name__ == "__main__":
    sys.exit(main())
