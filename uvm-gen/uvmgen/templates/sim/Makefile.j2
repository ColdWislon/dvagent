# ==============================================================================
# {{ ip }} simulation Makefile — generated by uvm-gen {{ gen_version }}
# Cadence Xcelium ONLY (single-step xrun, bundled UVM-1.2).
#
#   make compile                                   compile + elaborate sanity
#   make run TEST={{ ip }}_smoke_test [SEED=n]     single test run
#   make run TEST=x CFG=cfg/{{ ip }}_small.yaml    run under another config
#   make waves TEST=x                              rerun with SHM probing
#   make regress                                   launch the vManager session
#   make matrix                                    verification status summary
#   make clean
#
# This Makefile is the single source of truth for the xrun invocation: the
# generated .vsif files call back into `make run`, so local and vManager runs
# always use identical options.
# ==============================================================================

IP_NAME := {{ ip }}
TB_TOP  := {{ ip }}_tb_top
PYTHON  ?= python3
XRUN    ?= xrun

SIM_DIR  := $(abspath $(dir $(lastword $(MAKEFILE_LIST))))
ENV_ROOT := $(abspath $(SIM_DIR)/..)

# Anchor for all generated filelist paths (also what SoC glue filelists use
# to pull this env in from anywhere).
export {{ IP }}_VERIF_HOME := $(ENV_ROOT)

# Single knob for the Cadence VIP installation. vip_*.f files reference
# $CDN_VIP_ROOT directly, so moving a VIP install needs exactly one edit
# (or: export CDN_VIP_ROOT=/path before calling make).
export CDN_VIP_ROOT

# ------------------------------------------------------------------------------
# Active configuration (multi-configuration IP support).
# CFG is resolved relative to the env root first, then as given.
# ------------------------------------------------------------------------------
CFG ?= {{ cfg_rel_from_root }}
CFG_PATH = $(firstword $(wildcard $(ENV_ROOT)/$(CFG)) $(wildcard $(CFG)))

CFG2ARGS       = $(PYTHON) $(SIM_DIR)/scripts/cfg2args.py
CFG_NAME       = $(shell $(CFG2ARGS) --config-name $(CFG_PATH))
PARAM_HASH     = $(shell $(CFG2ARGS) --param-hash $(CFG_PATH))
CFG_XRUN_ARGS  = $(shell $(CFG2ARGS) --xrun-args $(CFG_PATH) --tb-top $(TB_TOP))
DUT_FILELIST   = $(shell $(CFG2ARGS) --dut-filelist $(CFG_PATH))
HAS_VIPS       = $(shell $(CFG2ARGS) --has-vips $(CFG_PATH))
VIP_PROTOS     = $(shell $(CFG2ARGS) --vip-protocols $(CFG_PATH))
VSIF           = $(SIM_DIR)/$(shell $(CFG2ARGS) --vsif-name $(CFG_PATH))

# ------------------------------------------------------------------------------
# Filelists — one -f per domain, never merged (design first, then DV).
# Append site extras (models, SoC glue, ...) via EXTRA_FILELISTS or FILELISTS+=.
# ------------------------------------------------------------------------------
TB_FILELIST   := $(SIM_DIR)/tb.f
VIP_FILELISTS = $(foreach p,$(VIP_PROTOS),$(SIM_DIR)/vip_$(p).f)

# DUT: real RTL when the configured filelist exists, generated stub otherwise.
# Override with USE_DUT_STUB=1 (force stub) or USE_DUT_STUB=0 (force RTL).
USE_DUT_STUB ?= auto
ifeq ($(USE_DUT_STUB),1)
DUT_F =
else ifeq ($(USE_DUT_STUB),0)
DUT_F = $(DUT_FILELIST)
else
DUT_F = $(if $(DUT_FILELIST),$(wildcard $(DUT_FILELIST)),)
endif
STUB_ARGS = $(if $(DUT_F),,+define+{{ IP }}_USE_DUT_STUB)

FILELISTS ?= $(strip $(DUT_F) $(VIP_FILELISTS) $(TB_FILELIST))
FILELISTS += $(EXTRA_FILELISTS)
XRUN_F_ARGS = $(foreach f,$(FILELISTS),-f $(f))

# ------------------------------------------------------------------------------
# xrun — single step, Xcelium-bundled UVM-1.2. Extra flags: XRUN_OPTS=...
# ------------------------------------------------------------------------------
TEST ?= {{ ip }}_smoke_test
SEED ?= 1
UVM_VERBOSITY ?= UVM_MEDIUM

RESULTS_DIR = $(SIM_DIR)/results/$(CFG_NAME)
LOG         = $(RESULTS_DIR)/$(TEST)_seed$(SEED).log

XRUN_ARGS = -64bit -sv -uvmhome CDNS-1.2 -timescale 1ns/1ps \
            $(XRUN_F_ARGS) $(STUB_ARGS) $(CFG_XRUN_ARGS) \
            -top $(TB_TOP)

.PHONY: compile run waves regress matrix clean help check_cfg check_vip dirs

compile: check_cfg check_vip dirs
	cd $(SIM_DIR) && $(XRUN) $(XRUN_ARGS) -elaborate \
	  -l $(RESULTS_DIR)/compile.log $(XRUN_OPTS)

run: check_cfg check_vip dirs
	cd $(SIM_DIR) && $(XRUN) $(XRUN_ARGS) \
	  +UVM_TESTNAME=$(TEST) +UVM_VERBOSITY=$(UVM_VERBOSITY) \
	  -svseed $(SEED) -l $(LOG) $(XRUN_OPTS) ; xrun_status=$$? ; \
	$(PYTHON) $(SIM_DIR)/scripts/record_result.py \
	  --matrix $(ENV_ROOT)/verif_matrix.yaml --config $(CFG_PATH) \
	  --test $(TEST) --seed "$(SEED)" --log $(LOG) --xrun-status $$xrun_status ; \
	exit $$xrun_status

waves: check_cfg check_vip dirs
	cd $(SIM_DIR) && $(XRUN) $(XRUN_ARGS) \
	  +UVM_TESTNAME=$(TEST) +UVM_VERBOSITY=$(UVM_VERBOSITY) \
	  -svseed $(SEED) -access +rwc -input $(SIM_DIR)/scripts/waves.tcl \
	  -l $(RESULTS_DIR)/$(TEST)_seed$(SEED)_waves.log $(XRUN_OPTS)

# vManager regression: one session per configuration
# ($(VSIF) is derived from CFG; sessions are named {{ ip }}_<config_name>).
regress: check_cfg check_vip
	@test -f "$(VSIF)" || { \
	  echo "ERROR: $(VSIF) not found."; \
	  echo "       Each configuration has its own vsif — re-run the generator"; \
	  echo "       with $(CFG_PATH) to create it."; \
	  exit 1; }
	cd $(SIM_DIR) && vmanager -execcmd "launch $(notdir $(VSIF))"

matrix:
	@$(PYTHON) $(SIM_DIR)/scripts/matrix_report.py $(ENV_ROOT)/verif_matrix.yaml

check_cfg:
	@test -n "$(CFG_PATH)" || { \
	  echo "ERROR: config '$(CFG)' not found (tried '$(ENV_ROOT)/$(CFG)' and '$(CFG)')"; \
	  exit 1; }
	@test -n "$(CFG_NAME)" || { \
	  echo "ERROR: cannot parse '$(CFG_PATH)':"; \
	  $(CFG2ARGS) --config-name $(CFG_PATH); \
	  exit 1; }
	@if [ -z "$(DUT_F)" ]; then \
	  echo "note: DUT RTL filelist not available ($(if $(DUT_FILELIST),$(DUT_FILELIST),not set in $(CFG_PATH)))"; \
	  echo "      compiling with the generated DUT stub (+define+{{ IP }}_USE_DUT_STUB)"; \
	fi

# A config that requests Cadence VIPs refuses to run without $CDN_VIP_ROOT.
check_vip:
	@if [ "$(HAS_VIPS)" = "1" ] && [ -z "$(CDN_VIP_ROOT)" ]; then \
	  echo "ERROR: configuration '$(CFG_PATH)' requests Cadence VIP(s): $(VIP_PROTOS)"; \
	  echo "       but \$$CDN_VIP_ROOT is not set."; \
	  echo "       Point it at your Cadence VIP installation, e.g."; \
	  echo "           export CDN_VIP_ROOT=/tools/cadence/vip"; \
	  echo "       (VIP compile filelists: $(VIP_FILELISTS))"; \
	  exit 1; \
	fi

dirs:
	@mkdir -p $(RESULTS_DIR)

clean:
	rm -rf $(SIM_DIR)/xcelium.d $(SIM_DIR)/xrun.history $(SIM_DIR)/xrun.log \
	       $(SIM_DIR)/xrun.key $(SIM_DIR)/waves.shm $(SIM_DIR)/*.shm \
	       $(SIM_DIR)/.simvision $(SIM_DIR)/results $(SIM_DIR)/vm_results \
	       $(SIM_DIR)/*.diag $(SIM_DIR)/.bpad

help:
	@echo "{{ ip }} verification environment (uvm-gen {{ gen_version }}) — targets:"
	@echo "  compile              compile + elaborate only (sanity)"
	@echo "  run TEST=<t>         run one test    [SEED=<n|random>] [CFG=cfg/<c>.yaml]"
	@echo "  waves TEST=<t>       run with -access +rwc and SHM probing"
	@echo "  regress              vManager: launch the vsif of the active CFG"
	@echo "  matrix               config-vs-status summary from verif_matrix.yaml"
	@echo "  clean                remove simulation artifacts"
	@echo "variables: CFG TEST SEED UVM_VERBOSITY XRUN_OPTS EXTRA_FILELISTS USE_DUT_STUB"
