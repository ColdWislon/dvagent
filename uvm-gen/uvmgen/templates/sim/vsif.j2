// ============================================================================
// vManager regression: {{ ip }} — configuration '{{ config_name }}'
// (generated by uvm-gen {{ gen_version }}; one vsif per configuration)
//
// Launch from the sim directory (paths anchor on $ENV(PWD)):
//     make regress CFG={{ cfg_rel_from_root }}
//  or vmanager -execcmd "launch {{ vsif_name }}"
//
// Every test's run_script calls back into `make run`, so the xrun options
// have a single source of truth (sim/Makefile) for local and vManager runs.
// Each run appends a record to ../verif_matrix.yaml (see `make matrix`).
// ============================================================================

session {{ ip }}_{{ config_name }} {
    top_dir : $ENV(PWD)/vm_results;
    output_mode : log_only;
};

group smoke {
    test {{ ip }}_smoke_test {
        run_script : "make -C $ENV(PWD) run TEST={{ ip }}_smoke_test CFG={{ cfg_rel_from_root }} SEED=$ATTR(seed)";
        scan_script : "vm_scan.pl ius.flt uvm.flt shell.flt";
        count : 1;
        seed : random;
    };
};

