// -----------------------------------------------------------------------------
// {{ ip }}_smoke_test — reset + a few transactions through {{ ip }}_smoke_vseq
// Generated by uvm-gen {{ gen_version }}; runnable immediately after
// generation (UVM_ERROR count 0 with the DUT stub).
//
// Vertical-reuse check without touching a single source file:
//   make run TEST={{ ip }}_smoke_test XRUN_OPTS=+{{ IP }}_PASSIVE=all
// flips every agent passive via {{ ip }}_env_cfg — drivers/sequencers are not
// built, monitors/scoreboard/coverage stay live, the test still passes.
// -----------------------------------------------------------------------------
`ifndef {{ IP }}_SMOKE_TEST_SV
`define {{ IP }}_SMOKE_TEST_SV

class {{ ip }}_smoke_test extends {{ ip }}_base_test;

  `uvm_component_utils({{ ip }}_smoke_test)

  function new(string name = "{{ ip }}_smoke_test", uvm_component parent = null);
    super.new(name, parent);
  endfunction

  virtual task run_phase(uvm_phase phase);
    {{ ip }}_smoke_vseq vseq;
    phase.raise_objection(this, "{{ ip }} smoke");
    vseq = {{ ip }}_smoke_vseq::type_id::create("vseq");
    if (!vseq.randomize())
      `uvm_fatal(get_type_name(), "randomize() failed for smoke vseq")
    vseq.start(m_env.m_vsequencer);
    #100ns;  // let trailing transactions land in monitors/scoreboard
    phase.drop_objection(this, "{{ ip }} smoke");
  endtask

endclass : {{ ip }}_smoke_test

`endif // {{ IP }}_SMOKE_TEST_SV
