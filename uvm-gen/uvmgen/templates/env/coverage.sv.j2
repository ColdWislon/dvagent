`ifndef {{ IP }}_{{ agent.NAME }}_COVERAGE_SV
`define {{ IP }}_{{ agent.NAME }}_COVERAGE_SV

class {{ ip }}_{{ agent.name }}_coverage extends uvm_subscriber #({{ ip }}_{{ agent.name }}_seq_item);

  {{ ip }}_{{ agent.name }}_agent_cfg cfg;

  // last sampled transaction (covergroup sampling source)
  {{ ip }}_{{ agent.name }}_seq_item tr;

  covergroup {{ agent.name }}_cg;
    option.per_instance = 1;
    option.name = "{{ ip }}_{{ agent.name }}_cov";
    // Example coverpoint on the stub 'data' field — replace with the real plan
    cp_data_low_byte : coverpoint tr.data[7:0] {
      bins zeros = {8'h00};
      bins low   = {[8'h01 : 8'h7F]};
      bins high  = {[8'h80 : 8'hFE]};
      bins ones  = {8'hFF};
    }
    // TODO(coverage): add protocol coverpoints and crosses, e.g.
    //   cp_kind : coverpoint tr.kind;
    //   x_kind_data : cross cp_kind, cp_data_low_byte;
  endgroup

  `uvm_component_utils({{ ip }}_{{ agent.name }}_coverage)

  function new(string name, uvm_component parent);
    super.new(name, parent);
    {{ agent.name }}_cg = new();
  endfunction

  virtual function void write({{ ip }}_{{ agent.name }}_seq_item t);
    if (cfg != null && !cfg.coverage_enable) return;
    tr = t;
    {{ agent.name }}_cg.sample();
  endfunction

endclass : {{ ip }}_{{ agent.name }}_coverage

`endif // {{ IP }}_{{ agent.NAME }}_COVERAGE_SV
