// -----------------------------------------------------------------------------
// {{ ip }}_scoreboard — scoreboard stub with one analysis export per monitor
// Generated by uvm-gen {{ gen_version }}. Compare logic is TODO.
// -----------------------------------------------------------------------------
`ifndef {{ IP }}_SCOREBOARD_SV
`define {{ IP }}_SCOREBOARD_SV

{% for n in all_ifs %}
`uvm_analysis_imp_decl(_{{ n.name }})
{% endfor %}

class {{ ip }}_scoreboard extends uvm_scoreboard;

  {{ ip }}_env_cfg cfg;

{% for n in all_ifs %}
  uvm_analysis_imp_{{ n.name }} #({{ n.item_type }}, {{ ip }}_scoreboard) {{ n.name }}_export;
  {{ n.item_type }} {{ n.name }}_q[$];
{% endfor %}

  int unsigned num_observed;

  `uvm_component_utils({{ ip }}_scoreboard)

  function new(string name, uvm_component parent);
    super.new(name, parent);
{% for n in all_ifs %}
    {{ n.name }}_export = new("{{ n.name }}_export", this);
{% endfor %}
  endfunction

{% for a in agents %}
  virtual function void write_{{ a.name }}({{ a.item_type }} t);
    num_observed++;
    {{ a.name }}_q.push_back(t);
    `uvm_info(get_type_name(), $sformatf("[{{ a.name }}] observed: %s", t.convert2string()), UVM_HIGH)
    // TODO(scoreboard): compare against the reference model / expected queue
  endfunction

{% endfor %}
{% for v in vips %}
  virtual function void write_{{ v.name }}({{ v.item_type }} t);
    num_observed++;
    {{ v.name }}_q.push_back(t);
    // TODO(scoreboard): $cast to the Cadence {{ v.title }} VIP transaction type and compare
  endfunction

{% endfor %}
  virtual function void check_phase(uvm_phase phase);
    super.check_phase(phase);
    // TODO(scoreboard): flag unmatched/leftover transactions here
  endfunction

  virtual function void report_phase(uvm_phase phase);
    super.report_phase(phase);
    `uvm_info(get_type_name(),
              $sformatf("observed %0d transaction(s) in total", num_observed), UVM_LOW)
  endfunction

endclass : {{ ip }}_scoreboard

`endif // {{ IP }}_SCOREBOARD_SV
