// -----------------------------------------------------------------------------
// {{ ip }}_env_cfg — THE single configuration object of the {{ ip }} env
// Generated by uvm-gen {{ gen_version }}.
//
// Vertical-reuse contract: this object is everything a parent must provide.
//   * standalone: {{ ip }}_base_test creates it, fills the virtual interfaces,
//     and publishes it via uvm_config_db under the env instance;
//   * SoC: the SoC env creates it, sets every agent to UVM_PASSIVE, points
//     the vifs at SoC signals, sets env_owns_bus=0 — zero source edits.
// All virtual interfaces live in the sub-configs below; no component ever
// fetches one from the config_db by hierarchical path.
// -----------------------------------------------------------------------------
`ifndef {{ IP }}_ENV_CFG_SV
`define {{ IP }}_ENV_CFG_SV

class {{ ip }}_env_cfg extends uvm_object;

  // ---------------------------------------------------------------------------
  // Configuration identity (multi-configuration IP support)
  // Baked defaults come from the YAML the generator ran with; `make run
  // CFG=cfg/<other>.yaml` overrides them at run time via plusargs
  // (+{{ IP }}_CFG_NAME=... +{{ IP }}_CFG_HASH=... +{{ IP }}_PARAM=NAME=VALUE).
  // ---------------------------------------------------------------------------
  string config_name = "{{ config_name }}";
  string param_hash  = "{{ param_hash }}";

  // Full parameter set (NAME -> value as string)
  string params[string];

{% if params %}
  // Typed mirrors of the generation-time parameters, sync'd by apply_params()
  // — use these to adapt env behavior/coverage to the configuration.
{% for p in params %}
  {{ p.sv_type }} {{ p.field }} = {{ p.sv_default }};  // {{ p.name }}
{% endfor %}

{% endif %}
  // ---------------------------------------------------------------------------
  // Feature switches
  // ---------------------------------------------------------------------------
  bit enable_scoreboard = 1;
  bit enable_coverage   = 1;

  // RAL hook
  bit has_ral      = 1;              // build/hook the register model
  bit env_owns_bus = 1;              // SoC sets 0: adapter/predictor wiring off
  uvm_reg_addr_t ral_base_addr = 'h0;  // base offset for a standalone-built block
  {{ ip }}_reg_block regmodel;       // standalone: env builds it; SoC: set your child block

  // ---------------------------------------------------------------------------
  // Per-interface configurations (each owns its virtual interface)
  // ---------------------------------------------------------------------------
{% for a in agents %}
  {{ ip }}_{{ a.name }}_agent_cfg {{ a.name }}_cfg;
{% endfor %}
{% for v in vips %}
  {{ ip }}_{{ v.name }}_vip_cfg {{ v.name }}_cfg;
{% endfor %}

  `uvm_object_utils_begin({{ ip }}_env_cfg)
    `uvm_field_string(config_name, UVM_ALL_ON)
    `uvm_field_string(param_hash, UVM_ALL_ON)
  `uvm_object_utils_end

  function new(string name = "{{ ip }}_env_cfg");
    super.new(name);
{% for a in agents %}
    {{ a.name }}_cfg = {{ ip }}_{{ a.name }}_agent_cfg::type_id::create("{{ a.name }}_cfg");
{% endfor %}
{% for v in vips %}
    {{ v.name }}_cfg = {{ ip }}_{{ v.name }}_vip_cfg::type_id::create("{{ v.name }}_cfg");
{% endfor %}
{% for p in params %}
    params["{{ p.name }}"] = "{{ p.value }}";
{% endfor %}
  endfunction

  // ---------------------------------------------------------------------------
  // Sync the typed parameter mirrors from the generic 'params' map
  // ---------------------------------------------------------------------------
  function void apply_params();
{% for p in params %}
    if (params.exists("{{ p.name }}"))
{% if p.is_int %}
      {{ p.field }} = params["{{ p.name }}"].atoi();
{% else %}
      {{ p.field }} = params["{{ p.name }}"];
{% endif %}
{% endfor %}
  endfunction

  // ---------------------------------------------------------------------------
  // Flip one interface (or "all") active/passive by name — used by the
  // +{{ IP }}_PASSIVE= / +{{ IP }}_ACTIVE= overrides and handy for SoC code.
  // ---------------------------------------------------------------------------
  function void set_agent_activity(string agent_name, uvm_active_passive_enum activity);
    if (agent_name == "all") begin
{% for n in all_ifs %}
      {{ n.name }}_cfg.is_active = activity;
{% endfor %}
      return;
    end
    case (agent_name)
{% for n in all_ifs %}
      "{{ n.name }}": {{ n.name }}_cfg.is_active = activity;
{% endfor %}
      default: `uvm_warning("ENVCFG",
        {"unknown interface name in activity override: ", agent_name})
    endcase
  endfunction

  // ---------------------------------------------------------------------------
  // Apply command-line overrides:
  //   +{{ IP }}_CFG_NAME=<name>            configuration name
  //   +{{ IP }}_CFG_HASH=<hash>            parameter-set hash
  //   +{{ IP }}_PARAM=<NAME>=<VALUE>       repeatable, feeds 'params'
  //   +{{ IP }}_PASSIVE=<name|all[,name]>  flip interfaces passive
  //   +{{ IP }}_ACTIVE=<name|all[,name]>   flip interfaces active
  // ---------------------------------------------------------------------------
  function void apply_cmdline_overrides();
    uvm_cmdline_processor clp = uvm_cmdline_processor::get_inst();
    string all_args[$];
    string val;
    if (clp.get_arg_value("+{{ IP }}_CFG_NAME=", val)) config_name = val;
    if (clp.get_arg_value("+{{ IP }}_CFG_HASH=", val)) param_hash = val;
    clp.get_args(all_args);
    foreach (all_args[i]) begin
      string rest;
      if (arg_after_prefix(all_args[i], "+{{ IP }}_PARAM=", rest))
        store_param(rest);
      else if (arg_after_prefix(all_args[i], "+{{ IP }}_PASSIVE=", rest))
        apply_activity_list(rest, UVM_PASSIVE);
      else if (arg_after_prefix(all_args[i], "+{{ IP }}_ACTIVE=", rest))
        apply_activity_list(rest, UVM_ACTIVE);
    end
    apply_params();
  endfunction

  // Returns 1 and the remainder when 'arg' starts with 'prefix'
  local function bit arg_after_prefix(string arg, string prefix, output string rest);
    if (arg.len() <= prefix.len()) return 0;
    if (arg.substr(0, prefix.len()-1) != prefix) return 0;
    rest = arg.substr(prefix.len(), arg.len()-1);
    return 1;
  endfunction

  // Store one "NAME=VALUE" pair into 'params'
  local function void store_param(string kv);
    int eq_pos = -1;
    for (int i = 0; i < kv.len(); i++)
      if (kv[i] == "=") begin eq_pos = i; break; end
    if (eq_pos < 1) begin
      `uvm_warning("ENVCFG", {"malformed +{{ IP }}_PARAM (expected NAME=VALUE): ", kv})
      return;
    end
    params[kv.substr(0, eq_pos-1)] =
      (eq_pos == kv.len()-1) ? "" : kv.substr(eq_pos+1, kv.len()-1);
  endfunction

  // Apply an activity override to a comma-separated name list
  local function void apply_activity_list(string csv, uvm_active_passive_enum activity);
    int start_pos = 0;
    for (int i = 0; i <= csv.len(); i++) begin
      if (i == csv.len() || csv[i] == ",") begin
        if (i > start_pos)
          set_agent_activity(csv.substr(start_pos, i-1), activity);
        start_pos = i + 1;
      end
    end
  endfunction

  // ---------------------------------------------------------------------------
  // Configuration signature banner — printed by the base test in every
  // simulation so each run is attributable to an exact parameter set.
  // ---------------------------------------------------------------------------
  function string sprint_banner();
    string ruler = "================================================================================";
    string s;
    s = {"\n", ruler, "\n"};
    s = {s, "  {{ ip }} configuration signature\n"};
    s = {s, $sformatf("  config_name : %s\n", config_name)};
    s = {s, $sformatf("  param_hash  : %s\n", param_hash)};
    if (params.num() == 0) begin
      s = {s, "  params      : (none)\n"};
    end
    else begin
      s = {s, "  params      :\n"};
      foreach (params[k])
        s = {s, $sformatf("    %-24s = %s\n", k, params[k])};
    end
{% for n in all_ifs %}
    s = {s, $sformatf("  %-12s: %s\n", "{{ n.kind }} {{ n.name }}", {{ n.name }}_cfg.is_active.name())};
{% endfor %}
    s = {s, $sformatf("  ral         : %s (base_addr='h%0h, env_owns_bus=%0d)\n",
                      has_ral ? "on" : "off", ral_base_addr, env_owns_bus)};
    s = {s, ruler};
    return s;
  endfunction

endclass : {{ ip }}_env_cfg

`endif // {{ IP }}_ENV_CFG_SV
