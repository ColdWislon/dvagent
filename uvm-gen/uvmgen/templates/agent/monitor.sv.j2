`define {{ IP }}_{{ agent.NAME }}_MONITOR_SV

class {{ ip }}_{{ agent.name }}_monitor extends uvm_monitor;

  {{ ip }}_{{ agent.name }}_agent_cfg cfg;

  uvm_analysis_port #({{ ip }}_{{ agent.name }}_seq_item) analysis_port;

  `uvm_component_utils({{ ip }}_{{ agent.name }}_monitor)

  function new(string name, uvm_component parent);
    super.new(name, parent);
  endfunction

  virtual function void build_phase(uvm_phase phase);
    super.build_phase(phase);
    if (cfg == null && !uvm_config_db#({{ ip }}_{{ agent.name }}_agent_cfg)::get(this, "", "cfg", cfg))
      `uvm_fatal("NOCFG", "no {{ ip }}_{{ agent.name }}_agent_cfg — the agent assigns it before build")
    if (cfg.vif == null)
      `uvm_fatal("NOVIF", "cfg.vif is null — set the virtual interface in {{ ip }}_env_cfg")
    analysis_port = new("analysis_port", this);
  endfunction

  virtual task run_phase(uvm_phase phase);
    wait (cfg.vif.rst_n === 1'b1);
    forever begin
      @(cfg.vif.mon_cb);
      // -----------------------------------------------------------------------
      // TODO(protocol): reconstruct real '{{ agent.name }}' transactions. The
      // valid-pulse sampling below matches the generated driver stub so the
      // smoke test observes traffic out of the box.
      // -----------------------------------------------------------------------
      if (cfg.vif.mon_cb.valid === 1'b1) begin
        {{ ip }}_{{ agent.name }}_seq_item tr;
        tr = {{ ip }}_{{ agent.name }}_seq_item::type_id::create("tr");
        tr.data = cfg.vif.mon_cb.data;
        `uvm_info(get_type_name(), $sformatf("observed: %s", tr.convert2string()), UVM_HIGH)
        analysis_port.write(tr);
      end
    end
  endtask

endclass : {{ ip }}_{{ agent.name }}_monitor

`endif // {{ IP }}_{{ agent.NAME }}_MONITOR_SV
